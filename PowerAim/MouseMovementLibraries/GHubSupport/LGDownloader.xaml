<visuality:BaseDialog x:Class="PowerAim.Visuality.LGDownloader"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:visuality="clr-namespace:PowerAim.Visuality"
        mc:Ignorable="d"
        Title="LG Hub Downloader"
        Height="320"
        Width="520"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="False"
        Background="{DynamicResource FluentSurface1}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="&#xE7FC;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           Foreground="{DynamicResource FluentAccent}"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Text="LG Hub Downloader" />
            </StackPanel>
            <Button HorizontalAlignment="Right"
                    Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Content="&#xE8BB;" Width="46" Height="40" Padding="0" FontSize="10"
                    VerticalAlignment="Top"
                    Click="Exit_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="20,8,20,12">
            <StackPanel>
                <TextBlock Text="Choose a mirror"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="18"
                           Margin="0,0,0,8" />
                <TextBlock Foreground="{DynamicResource FluentTextSecondary}"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="13"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           Margin="0,0,0,14"
                           Text="Pick a host to download Logitech G HUB from. PowerAim verifies the downloaded file's size and MD5 hash before launching the installer." />

                <Border Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="6">
                    <StackPanel>
                        <Button Tag="https://download01.logi.com/web/ftp/pub/techsupport/gaming/lghub_installer_2021.3.5164.exe"
                                Style="{DynamicResource FluentStandardButton}"
                                HorizontalContentAlignment="Stretch"
                                Padding="12,8,12,8"
                                Margin="0,0,0,4"
                                Click="DownloadFile">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="&#xE896;"
                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="LG Direct"
                                               Foreground="{DynamicResource FluentTextPrimary}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                    <TextBlock Text="download01.logi.com (official)"
                                               Foreground="{DynamicResource FluentTextTertiary}"
                                               FontFamily="Segoe UI Variable Small"
                                               FontSize="11" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="&#xE76C;"
                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="11"
                                           Foreground="{DynamicResource FluentTextTertiary}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Button Tag="https://download01.logi.com/web/ftp/pub/techsupport/gaming/lghub_installer_2021.3.5164.exe"
                                Style="{DynamicResource FluentStandardButton}"
                                HorizontalContentAlignment="Stretch"
                                Padding="12,8,12,8"
                                Margin="0,0,0,4"
                                Click="DownloadFile">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="&#xEC05;"
                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Supercomet CDN"
                                               Foreground="{DynamicResource FluentTextPrimary}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                    <TextBlock Text="Alternate mirror"
                                               Foreground="{DynamicResource FluentTextTertiary}"
                                               FontFamily="Segoe UI Variable Small"
                                               FontSize="11" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="&#xE76C;"
                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="11"
                                           Foreground="{DynamicResource FluentTextTertiary}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Button Tag="https://raw.githubusercontent.com/DEVIX7/other_code/backup/backup/lghub_installer_2021.3.5164.exe.zip"
                                Style="{DynamicResource FluentStandardButton}"
                                HorizontalContentAlignment="Stretch"
                                Padding="12,8,12,8"
                                Click="DownloadFile"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="&#xE71B;"
                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="99'developer's GitHub"
                                               Foreground="{DynamicResource FluentTextPrimary}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                    <TextBlock Text="GitHub mirror (.zip)"
                                               Foreground="{DynamicResource FluentTextTertiary}"
                                               FontFamily="Segoe UI Variable Small"
                                               FontSize="11" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="&#xE76C;"
                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="11"
                                           Foreground="{DynamicResource FluentTextTertiary}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

                <TextBlock Foreground="{DynamicResource FluentTextTertiary}"
                           FontFamily="Segoe UI Variable Small"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"
                           Text="Tip: after installing, disable LG HUB's automatic updates so the SDK PowerAim depends on doesn't break." />
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="20,0,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1"
                    Content="Close"
                    MinWidth="110" MinHeight="34"
                    Padding="14,6,14,6"
                    Style="{DynamicResource FluentStandardButton}"
                    Click="Exit_Click" />
        </Grid>
    </Grid>
</visuality:BaseDialog>
