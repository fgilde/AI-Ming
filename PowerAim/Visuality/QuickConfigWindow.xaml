<Window x:Class="PowerAim.Visuality.QuickConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="-10000"
        Top="-10000"
        Topmost="False"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <!-- one config row -->
        <Style x:Key="QcRow" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="10,7,14,7" />
            <Setter Property="Margin" Value="0,1,0,1" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource FluentHoverOverlay}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="{DynamicResource FluentSurface2}"
            BorderBrush="{DynamicResource FluentStroke}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="6"
            MinWidth="230">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="5" Opacity="0.5" Color="#000000" />
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="QUICK CONFIG"
                       Margin="10,5,10,7"
                       FontFamily="Segoe UI Variable Small"
                       FontSize="10.5"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource FluentTextTertiary}" />
            <StackPanel x:Name="ConfigList" />
            <Border Height="1" Background="{DynamicResource FluentStroke}" Margin="6,6,6,5" />
            <Border x:Name="SaveCurrentRow" Style="{StaticResource QcRow}" MouseLeftButtonUp="SaveCurrent_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE710;"
                               FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,9,0"
                               Foreground="{DynamicResource FluentTextSecondary}" />
                    <TextBlock x:Name="SaveCurrentText"
                               Text="Save current as…"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               Foreground="{DynamicResource FluentTextSecondary}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
