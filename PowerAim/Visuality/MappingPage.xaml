<UserControl x:Class="PowerAim.Visuality.MappingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uilib="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="800" d:DesignWidth="1100">
    <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
        <StackPanel Margin="20,16,20,16">

            <!-- ============ Active + Direction ============ -->
            <Border Style="{StaticResource FluentCard}">
                <StackPanel>
                    <TextBlock Text="Controller ↔ Keyboard Mapping"
                               Foreground="{DynamicResource FluentTextPrimary}"
                               FontFamily="Segoe UI Variable Display"
                               FontWeight="SemiBold" FontSize="16"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Make games respond to whichever input device they don't natively support — kb+mouse drives a virtual gamepad, or a controller drives kb+mouse. Pick a profile and a direction; flip the master switch when you're ready to play."
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text" FontSize="12"
                               TextWrapping="Wrap" LineHeight="18"
                               Margin="0,0,0,12" />

                    <!-- Master active toggle with global hotkey support -->
                    <StackPanel x:Name="ActiveHost" Margin="0,0,0,8" />

                    <!-- Engine status line -->
                    <TextBlock x:Name="EngineStatusText"
                               Foreground="{DynamicResource FluentTextTertiary}"
                               FontFamily="Segoe UI Variable Small" FontSize="11"
                               Margin="2,10,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- ============ Profile list ============ -->
            <Border Style="{StaticResource FluentCard}">
                <StackPanel>
                    <TextBlock Text="Mapping profiles"
                               Foreground="{DynamicResource FluentTextPrimary}"
                               FontFamily="Segoe UI Variable Display"
                               FontWeight="SemiBold" FontSize="14"
                               Margin="0,0,0,8" />
                    <TextBlock Text="One active profile at a time — the engine picks the first enabled profile whose 'match process' (if any) is focused. Click the pencil to edit, the diamond to duplicate, the bin to delete."
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Small" FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <uilib:MappingProfileList x:Name="ProfileList" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
