<visuality:BaseDialog x:Class="Visuality.AutoPlayProfileEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Visuality"
        xmlns:uiLibrary="clr-namespace:UILibrary"
        xmlns:visuality="clr-namespace:PowerAim.Visuality"
        mc:Ignorable="d"
        Title="{Binding Converter={StaticResource localeConverter}, ConverterParameter='EditAutoPlayProfile'}"
        Height="640"
        Width="580"
        MinHeight="500"
        MinWidth="420"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="False"
        Background="{StaticResource FluentSurface1}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="&#xE768;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           Foreground="{DynamicResource FluentAccent}"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=local:AutoPlayProfileEditDialog}}"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="13" />
            </StackPanel>
            <Button x:Name="Exit"
                    Content="&#xE8BB;"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Width="46"
                    Height="40"
                    Padding="0"
                    FontSize="10"
                    VerticalAlignment="Top"
                    Click="Exit_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource FluentCard}" Margin="14,4,14,8" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <uiLibrary:AutoPlayProfileEdit x:Name="ProfileEdit" Margin="14,10,14,10" />
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="14,0,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding Profile.Description}"
                       Visibility="{Binding Converter={StaticResource helpVis}}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       TextTrimming="WordEllipsis"
                       Foreground="{DynamicResource FluentTextSecondary}" />
            <Button Grid.Column="1"
                    x:Name="CancelButton"
                    Style="{StaticResource FluentStandardButton}"
                    Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Cancel'}"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Click="Exit_Click" />
            <Button Grid.Column="2"
                    x:Name="SaveButton"
                    IsEnabled="{Binding Profile.IsValid}"
                    Style="{StaticResource FluentAccentButton}"
                    Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Save'}"
                    MinWidth="100"
                    Click="SaveButton_Click" />
        </Grid>
    </Grid>
</visuality:BaseDialog>
