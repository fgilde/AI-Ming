<visuality:BaseDialog x:Class="PowerAim.Visuality.GamepadDiagnosticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:visuality="clr-namespace:PowerAim.Visuality"
        Title="Gamepad Diagnostics"
        Height="600"
        Width="640"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="False"
        Background="{DynamicResource FluentSurface1}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="&#xE9D9;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           Foreground="{DynamicResource FluentAccent}"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Text="Gamepad Diagnostics" />
            </StackPanel>
            <Button HorizontalAlignment="Right"
                    Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Content="&#xE8BB;" Width="46" Height="40" Padding="0" FontSize="10"
                    VerticalAlignment="Top"
                    Click="Close_Click" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0,20,0">
            <StackPanel>
                <TextBlock Text="What PowerAim sees in your system right now."
                           Foreground="{DynamicResource FluentTextSecondary}"
                           FontFamily="Segoe UI Variable Text" FontSize="13"
                           Margin="0,4,0,12"
                           TextWrapping="Wrap" />

                <Border Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="XInput slots (the 4 controllers Windows tracks)"
                                   Foreground="{DynamicResource FluentTextPrimary}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold" FontSize="13"
                                   Margin="0,0,0,8" />
                        <StackPanel x:Name="SlotsPanel" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="PowerAim sender status"
                                   Foreground="{DynamicResource FluentTextPrimary}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold" FontSize="13"
                                   Margin="0,0,0,8" />
                        <StackPanel x:Name="SenderPanel" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentAccent}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Suggested action"
                                   Foreground="{DynamicResource FluentAccent}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold" FontSize="13"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="SuggestionText"
                                   Foreground="{DynamicResource FluentTextPrimary}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="20" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="20,8,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Fire test RT pulse"
                    MinHeight="34" Padding="14,6,14,6"
                    Style="{DynamicResource FluentStandardButton}"
                    Click="TestPulse_Click" />
            <Button Grid.Column="2" Content="Refresh"
                    MinHeight="34" Padding="14,6,14,6"
                    Style="{DynamicResource FluentAccentButton}"
                    Click="Refresh_Click" />
        </Grid>
    </Grid>
</visuality:BaseDialog>
