<visuality:BaseDialog x:Class="PowerAim.Visuality.CalibrationWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:visuality="clr-namespace:PowerAim.Visuality"
        mc:Ignorable="d"
        Title="{Binding Converter={StaticResource localeConverter}, ConverterParameter='SensitivityCalibration'}"
        Height="520"
        Width="600"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="False"
        Background="{DynamicResource FluentSurface1}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="&#xEC4A;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           Foreground="{DynamicResource FluentAccent}"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='SensitivityCalibrationWizard'}" />
            </StackPanel>
            <Button HorizontalAlignment="Right"
                    Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Content="&#xE8BB;" Width="46" Height="40" Padding="0" FontSize="10"
                    VerticalAlignment="Top"
                    Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="20,8,20,12">
            <!-- Step 1: Welcome -->
            <Border x:Name="WelcomePanel" Visibility="Visible">
                <StackPanel>
                    <TextBlock Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CalibrateToYourGame'}"
                               Foreground="{DynamicResource FluentTextPrimary}"
                               FontFamily="Segoe UI Variable Display"
                               FontWeight="SemiBold"
                               FontSize="20"
                               Margin="0,0,0,12" />
                    <TextBlock Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               TextWrapping="Wrap"
                               LineHeight="20"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CalibrationIntroBody'}" />
                    <TextBlock Foreground="{DynamicResource FluentTextPrimary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"
                               LineHeight="20"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CalibrationBeforeYouStart'}" />
                    <TextBlock Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               LineHeight="20"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CalibrationBulletList'}" />
                    <TextBlock Foreground="{DynamicResource FluentTextTertiary}"
                               FontFamily="Segoe UI Variable Small"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,16,0,0"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CalibrationTip'}" />
                </StackPanel>
            </Border>

            <!-- Step 2: Running -->
            <Border x:Name="RunningPanel" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="RunningStatus"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CalibrationRunning'}"
                               Foreground="{DynamicResource FluentTextPrimary}"
                               FontFamily="Segoe UI Variable Display"
                               FontWeight="SemiBold"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <TextBlock Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='DontMoveMouse'}"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20" />
                    <ProgressBar x:Name="RunningProgress"
                                 IsIndeterminate="True"
                                 Height="6"
                                 Width="320"
                                 Foreground="{DynamicResource FluentAccent}" />
                </StackPanel>
            </Border>

            <!-- Step 3: Result -->
            <Border x:Name="ResultPanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="ResultHeader"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Result'}"
                               Foreground="{DynamicResource FluentTextPrimary}"
                               FontFamily="Segoe UI Variable Display"
                               FontWeight="SemiBold"
                               FontSize="20"
                               Margin="0,0,0,10" />
                    <Border Background="{DynamicResource FluentSurface2}"
                            BorderBrush="{DynamicResource FluentStroke}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='MeasuredPixelsPerInput'}"
                                           Foreground="{DynamicResource FluentTextSecondary}"
                                           FontFamily="Segoe UI Variable Text" FontSize="13" />
                                <TextBlock Grid.Column="1" x:Name="RatioText"
                                           Foreground="{DynamicResource FluentTextPrimary}"
                                           FontFamily="Segoe UI Variable Text" FontWeight="SemiBold" FontSize="13" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='SamplesUsed'}"
                                           Foreground="{DynamicResource FluentTextSecondary}"
                                           FontFamily="Segoe UI Variable Text" FontSize="13" />
                                <TextBlock Grid.Column="1" x:Name="SamplesText"
                                           Foreground="{DynamicResource FluentTextPrimary}"
                                           FontFamily="Segoe UI Variable Text" FontSize="13" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CurrentMouseSensitivity'}"
                                           Foreground="{DynamicResource FluentTextSecondary}"
                                           FontFamily="Segoe UI Variable Text" FontSize="13" />
                                <TextBlock Grid.Column="1" x:Name="CurrentSensText"
                                           Foreground="{DynamicResource FluentTextPrimary}"
                                           FontFamily="Segoe UI Variable Text" FontSize="13" />
                            </Grid>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='SuggestedMouseSensitivity'}"
                                           Foreground="{DynamicResource FluentAccent}"
                                           FontFamily="Segoe UI Variable Text" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Grid.Column="1" x:Name="SuggestedSensText"
                                           Foreground="{DynamicResource FluentAccent}"
                                           FontFamily="Segoe UI Variable Text" FontWeight="SemiBold" FontSize="13" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="InterpretationText"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,14,0,0"
                               LineHeight="18" />
                </StackPanel>
            </Border>

            <!-- Step 4: Error -->
            <Border x:Name="ErrorPanel" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xEA39;"
                               FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                               Foreground="Tomato"
                               FontSize="40"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <TextBlock Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CalibrationFailed'}"
                               Foreground="{DynamicResource FluentTextPrimary}"
                               FontFamily="Segoe UI Variable Display"
                               FontWeight="SemiBold"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock x:Name="ErrorText"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="420" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="20,0,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="LeftButton" Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Cancel'}"
                    MinWidth="110" MinHeight="34"
                    Margin="0,0,8,0" Padding="14,6,14,6"
                    Style="{DynamicResource FluentStandardButton}"
                    Click="LeftButton_Click" />
            <Button Grid.Column="2" x:Name="RightButton" Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='StartCalibration'}"
                    MinWidth="160" MinHeight="34"
                    Padding="14,6,14,6"
                    Style="{DynamicResource FluentAccentButton}"
                    Click="RightButton_Click" />
        </Grid>
    </Grid>
</visuality:BaseDialog>
