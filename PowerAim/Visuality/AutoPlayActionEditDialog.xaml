<visuality:BaseDialog x:Class="Visuality.AutoPlayActionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
        xmlns:uiLibrary1="clr-namespace:UILibrary"
        xmlns:local="clr-namespace:Visuality"
        xmlns:visuality="clr-namespace:PowerAim.Visuality"
        mc:Ignorable="d"
        Title="Edit Action"
        Height="540"
        Width="480"
        MinHeight="420"
        MinWidth="360"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="False"
        Background="{StaticResource FluentSurface1}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="&#xE7C4;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           Foreground="{DynamicResource FluentAccent}"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=local:AutoPlayActionEditDialog}}"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="13" />
            </StackPanel>
            <Button x:Name="Exit"
                    Content="&#xE8BB;"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Width="46"
                    Height="40"
                    Padding="0"
                    FontSize="10"
                    VerticalAlignment="Top"
                    Click="Exit_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="14,4,14,8" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Action Name -->
                <TextBlock Style="{StaticResource FluentSectionTitle}" Text="Action Name" />
                <Border Background="{DynamicResource FluentSurface3}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBox BorderThickness="0"
                             Background="Transparent"
                             Padding="10,8,10,8"
                             Text="{Binding Action.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Tag="e.g. move_left, jump, attack..."
                             FontFamily="Segoe UI Variable Text"
                             FontSize="13"
                             Style="{DynamicResource placeHolder}"
                             Foreground="{DynamicResource FluentTextPrimary}" />
                </Border>
                <TextBlock Foreground="{DynamicResource FluentTextTertiary}"
                           FontSize="11"
                           Margin="2,4,0,12"
                           TextWrapping="Wrap"
                           Visibility="{Binding Converter={StaticResource helpVis}}"
                           Text="The name the AI will use to trigger this action. Use underscores, no spaces."
                           FontFamily="Segoe UI Variable Small" />

                <!-- Description -->
                <TextBlock Style="{StaticResource FluentSectionTitle}" Text="Description (for AI)" />
                <Border Background="{DynamicResource FluentSurface3}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBox BorderThickness="0"
                             Background="Transparent"
                             Padding="10,8,10,8"
                             Text="{Binding Action.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="60"
                             Tag="Describe what this action does..."
                             FontFamily="Segoe UI Variable Text"
                             FontSize="13"
                             Style="{DynamicResource placeHolder}"
                             Foreground="{DynamicResource FluentTextPrimary}" />
                </Border>
                <TextBlock Foreground="{DynamicResource FluentTextTertiary}"
                           FontSize="11"
                           Margin="2,4,0,12"
                           TextWrapping="Wrap"
                           Visibility="{Binding Converter={StaticResource helpVis}}"
                           Text="Help the AI understand when to use this action."
                           FontFamily="Segoe UI Variable Small" />

                <!-- Keys -->
                <TextBlock Style="{StaticResource FluentSectionTitle}" Text="Keys to Press" />
                <uiLibrary1:MultiKeyChanger Margin="0,4,0,0"
                                            Keys="{Binding Action.Keys, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Foreground="{DynamicResource FluentTextTertiary}"
                           FontSize="11"
                           Margin="2,4,0,12"
                           TextWrapping="Wrap"
                           Visibility="{Binding Converter={StaticResource helpVis}}"
                           Text="The keys/buttons that will be pressed when this action is executed."
                           FontFamily="Segoe UI Variable Small" />

                <!-- Duration -->
                <StackPanel x:Name="DurationPanel" Margin="0,4,0,0" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,14,14">
            <Button x:Name="CancelButton"
                    Style="{StaticResource FluentStandardButton}"
                    Content="Cancel"
                    Margin="0,0,8,0"
                    MinWidth="90"
                    Click="Exit_Click" />
            <Button x:Name="SaveButton"
                    IsEnabled="{Binding Action.IsValid}"
                    Style="{StaticResource FluentAccentButton}"
                    Content="Save"
                    MinWidth="100"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</visuality:BaseDialog>
