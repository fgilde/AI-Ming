<visuality:BaseDialog x:Class="PowerAim.Visuality.RecoilPatternsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:visuality="clr-namespace:PowerAim.Visuality"
        mc:Ignorable="d"
        Title="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='RecoilPatterns'}"
        Height="600"
        Width="880"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="False"
        Background="{DynamicResource FluentSurface1}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="&#xE945;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           Foreground="{DynamicResource FluentAccent}"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='RecoilPatterns'}" />
            </StackPanel>
            <Button HorizontalAlignment="Right"
                    Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Content="&#xE8BB;" Width="46" Height="40" Padding="0" FontSize="10"
                    VerticalAlignment="Top"
                    Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <TextBlock Grid.Row="1"
                   Margin="16,0,16,10"
                   Foreground="{DynamicResource FluentTextSecondary}"
                   FontFamily="Segoe UI Variable Small"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='RecoilPatternsHelp'}" />

        <Grid Grid.Row="2" Margin="16,0,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Pattern list -->
            <Border Grid.Column="0"
                    Background="{DynamicResource FluentSurface2}"
                    BorderBrush="{DynamicResource FluentStroke}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="6,6,6,6">
                        <ItemsControl x:Name="PatternItems" />
                    </ScrollViewer>
                    <Grid Grid.Row="1" Margin="8,4,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="RecordButton"
                                Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='RecordPattern2s'}"
                                Style="{DynamicResource FluentAccentButton}"
                                MinHeight="34"
                                Click="Record_Click" />
                        <Button Grid.Column="1" Margin="6,0,0,0"
                                x:Name="DeleteButton"
                                Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='DeleteSelected'}"
                                Style="{DynamicResource FluentStandardButton}"
                                MinHeight="34"
                                Click="Delete_Click" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Detail + preview -->
            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Name'}"
                                           Foreground="{DynamicResource FluentTextSecondary}"
                                           FontFamily="Segoe UI Variable Text" FontSize="12" />
                                <TextBox x:Name="NameBox" Margin="0,4,0,0" MinHeight="28"
                                         TextChanged="NameBox_TextChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Weapon'}"
                                           Foreground="{DynamicResource FluentTextSecondary}"
                                           FontFamily="Segoe UI Variable Text" FontSize="12" />
                                <TextBox x:Name="WeaponBox" Margin="0,4,0,0" MinHeight="28"
                                         TextChanged="WeaponBox_TextChanged" />
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="DurationText" Margin="0,8,0,0"
                                   Foreground="{DynamicResource FluentTextTertiary}"
                                   FontFamily="Segoe UI Variable Small" FontSize="11"
                                   Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='NoPatternSelected'}" />
                    </StackPanel>
                </Border>

                <!-- Preview canvas -->
                <Border Grid.Row="1" Margin="0,10,0,10"
                        Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <Canvas x:Name="PreviewCanvas" Background="{DynamicResource FluentSurface3}"
                            ClipToBounds="True" />
                </Border>

                <!-- Playback controls -->
                <Border Grid.Row="2"
                        Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <StackPanel>
                        <CheckBox x:Name="EnablePlaybackBox"
                                  Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='UsePatternPlayback'}"
                                  Foreground="{DynamicResource FluentTextPrimary}"
                                  FontFamily="Segoe UI Variable Text" FontSize="13"
                                  Margin="0,0,0,8"
                                  Checked="EnablePlayback_Toggle"
                                  Unchecked="EnablePlayback_Toggle" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='PatternStrength'}"
                                       Foreground="{DynamicResource FluentTextSecondary}"
                                       FontFamily="Segoe UI Variable Text" FontSize="12"
                                       VerticalAlignment="Center" />
                            <Slider x:Name="StrengthSlider" Grid.Column="1"
                                    Minimum="0" Maximum="2.0" TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="Strength_Changed" />
                            <TextBlock Grid.Column="2" x:Name="StrengthText"
                                       Foreground="{DynamicResource FluentTextPrimary}"
                                       FontFamily="Segoe UI Variable Text" FontSize="12"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Text="1.00" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="3" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusText"
                       Foreground="{DynamicResource FluentTextTertiary}"
                       FontFamily="Segoe UI Variable Small" FontSize="11"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
            <Button Grid.Column="1" x:Name="CloseButton" Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Close'}"
                    MinWidth="96" MinHeight="34"
                    Padding="14,6,14,6"
                    Style="{DynamicResource FluentStandardButton}"
                    Click="Cancel_Click" />
        </Grid>
    </Grid>
</visuality:BaseDialog>
