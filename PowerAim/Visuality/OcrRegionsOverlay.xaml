<Window x:Class="PowerAim.Visuality.OcrRegionsOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        WindowStartupLocation="Manual">
    <!-- AllowsTransparency=True + Background=Transparent means fully transparent pixels of the
         window pass mouse clicks through to the app underneath. The toolbar and the region
         visuals are the only opaque/semi-opaque pixels, so they're the only things that catch
         clicks. WS_EX_TOOLWINDOW + WS_EX_NOACTIVATE are added in code-behind to keep the
         overlay out of the taskbar and prevent focus-stealing. -->
    <Grid>
        <Canvas x:Name="RegionsCanvas" />

        <!-- Floating toolbar (top-left). Always interactive; users toggle "edit mode" here. -->
        <Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="20,20,0,0"
                Background="#CC1A1A22"
                BorderBrush="#3E3E4A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,8,12,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="ToolbarHeader"
                           Text="OCR Regions"
                           Foreground="#8B5CF6"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0" />
                <CheckBox x:Name="EditModeCheckBox"
                          Content="Edit"
                          Foreground="#E6E6F0"
                          FontFamily="Segoe UI Variable Text"
                          FontSize="11"
                          VerticalAlignment="Center"
                          Checked="EditModeCheckBox_CheckedChanged"
                          Unchecked="EditModeCheckBox_CheckedChanged" />

                <!-- Only visible in edit mode — adds a fresh region at the screen centre. -->
                <Button x:Name="AddRegionButton"
                        Margin="14,0,0,0"
                        Padding="10,3,12,3"
                        Visibility="Collapsed"
                        ToolTip="Add new OCR region"
                        Click="AddRegion_Click"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="#FF8B5CF6"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;"
                                               FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                               FontSize="11"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="New region"
                                               Foreground="White"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FFA77BFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
