<Window x:Class="PowerAim.Visuality.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
        Title="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Help'}"
        Height="820"
        Width="1100"
        MinWidth="640"
        MinHeight="540"
        ShowInTaskbar="True"
        Topmost="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource FluentSurface1}">
    <Grid Margin="14">
        <uiLibrary:HelpPanel x:Name="Panel" />
    </Grid>
</Window>
