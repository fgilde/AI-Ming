<visuality:BaseDialog x:Class="PowerAim.Visuality.CudaSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:visuality="clr-namespace:PowerAim.Visuality"
        mc:Ignorable="d"
        Title="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CudaSetupTitle'}"
        Height="560"
        Width="640"
        WindowStyle="None"
        Topmost="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="False"
        Background="{StaticResource FluentSurface1}">
    <visuality:BaseDialog.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
    </visuality:BaseDialog.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="&#xE950;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           Foreground="{DynamicResource FluentAccent}"
                           FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CudaSetupTitle'}"
                           Margin="10,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display" FontWeight="SemiBold" FontSize="13" />
            </StackPanel>
            <Button HorizontalAlignment="Right" Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Width="46" Height="44" Padding="0" FontSize="10" VerticalAlignment="Top"
                    Content="&#xE8BB;" Click="Close_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Content -->
        <Border Grid.Row="1" Style="{StaticResource FluentCard}" Margin="20,12,20,8" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="22,18,22,18">
                    <TextBlock FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource FluentTextPrimary}"
                               FontFamily="Segoe UI Variable Display"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CudaSetupHeading'}" />
                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text" FontSize="13" LineHeight="20"
                               Text="{Binding IntroText}" />

                    <!-- Active provider -->
                    <Border Margin="0,16,0,0" Padding="14,10" CornerRadius="6"
                            Background="{DynamicResource FluentSurface2}"
                            BorderBrush="{DynamicResource FluentStroke}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CudaSetupActiveProvider'}"
                                       Foreground="{DynamicResource FluentTextSecondary}"
                                       FontFamily="Segoe UI Variable Text" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ActiveProviderText}" Margin="8,0,0,0"
                                       Foreground="{DynamicResource FluentTextPrimary}"
                                       FontFamily="Segoe UI Variable Display" FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Stack pieces -->
                    <ItemsControl ItemsSource="{Binding StatusItems}" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Glyph}"
                                               Foreground="{Binding GlyphBrush}"
                                               FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                               FontSize="15" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource FluentTextPrimary}"
                                                   FontFamily="Segoe UI Variable Text" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Detail}" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource FluentTextSecondary}"
                                                   FontFamily="Segoe UI Variable Small" FontSize="11.5" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Progress (only while working) -->
        <StackPanel Grid.Row="2" Margin="24,0,24,4" Visibility="{Binding IsBusy, Converter={StaticResource B2V}}">
            <TextBlock Text="{Binding ProgressText}" Margin="0,0,0,4"
                       Foreground="{DynamicResource FluentTextSecondary}"
                       FontFamily="Segoe UI Variable Small" FontSize="12" />
            <ProgressBar Height="6" Minimum="0" Maximum="100"
                         Value="{Binding ProgressValue}"
                         IsIndeterminate="{Binding ProgressIndeterminate}" />
        </StackPanel>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="20,10,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Style="{DynamicResource FluentStandardButton}"
                    Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CudaSetupOpenNvidia'}"
                    Click="OpenNvidia_Click" IsEnabled="{Binding IsIdle}" />
            <Button Grid.Column="2"
                    Style="{DynamicResource FluentStandardButton}"
                    MinWidth="100" Margin="0,0,8,0"
                    Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='CudaSetupRecheck'}"
                    Click="Recheck_Click" IsEnabled="{Binding IsIdle}" />
            <Button Grid.Column="3"
                    x:Name="SetUpButton"
                    Style="{DynamicResource FluentAccentButton}"
                    MinWidth="150"
                    Content="{Binding SetUpButtonText}"
                    Visibility="{Binding CanShowSetup, Converter={StaticResource B2V}}"
                    Click="SetUp_Click" IsEnabled="{Binding IsIdle}" />
        </Grid>
    </Grid>
</visuality:BaseDialog>
