<Window x:Class="Visuality.ConfigLabelOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:poweraim="clr-namespace:PowerAim"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="ConfigLabelOverlay_OnMouseDown"
        WindowStartupLocation="Manual"
        Left="-10000"
        Top="-10000"
        Topmost="False">
    <!-- A small floating "tab" that sits just above the main window's top edge. It is a separate
         window so it renders OUTSIDE the main window without changing the main window's content. -->
    <Border Margin="14,14,14,0"
            Background="{DynamicResource FluentSurface2}"
            BorderBrush="{DynamicResource FluentStroke}"
            BorderThickness="1,1,1,0"
            CornerRadius="10,10,0,0"
            Padding="16,3,16,6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.45" Color="#000000" />
        </Border.Effect>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
            <!-- subtle accent arc over the name -->
            <Path Width="124" Height="6" Stretch="Fill"
                  Data="M0,6 Q62,-5 124,6"
                  Stroke="{DynamicResource FluentAccent}"
                  StrokeThickness="1.4"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Opacity="0.75"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,2" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Grid MinWidth="80" VerticalAlignment="Center">
                <TextBlock x:Name="ConfigLabelText"
                           Text="{Binding Config.EffectiveConfigLabel}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Cursor="Hand"
                           FontFamily="Segoe UI Variable Small"
                           FontWeight="SemiBold"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="300"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           MouseLeftButtonDown="ConfigLabel_BeginEdit" />
                <TextBox x:Name="ConfigLabelEdit"
                         Visibility="Collapsed"
                         MinWidth="100"
                         MaxWidth="300"
                         HorizontalAlignment="Center"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         FontFamily="Segoe UI Variable Small"
                         FontWeight="SemiBold"
                         FontSize="12"
                         MaxLength="40"
                         Padding="6,1,6,1"
                         Background="{DynamicResource FluentSurface3}"
                         Foreground="{DynamicResource FluentTextPrimary}"
                         BorderBrush="{DynamicResource FluentAccent}"
                         BorderThickness="1"
                         KeyDown="ConfigLabelEdit_KeyDown"
                         LostKeyboardFocus="ConfigLabelEdit_Commit" />
                </Grid>
                <TextBlock x:Name="ConfigChevron"
                           Text="&#xE70D;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           FontSize="9"
                           VerticalAlignment="Center"
                           Margin="8,1,0,0"
                           Cursor="Hand"
                           Foreground="{DynamicResource FluentTextSecondary}"
                           MouseLeftButtonDown="ConfigChevron_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
