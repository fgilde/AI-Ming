<Window x:Class="PowerAim.Visuality.ScreenRegionPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#33000000"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Cursor="Cross">
    <Canvas x:Name="RootCanvas"
            Background="Transparent"
            MouseLeftButtonDown="Root_MouseDown"
            MouseMove="Root_MouseMove"
            MouseLeftButtonUp="Root_MouseUp">
        <Rectangle x:Name="SelectionRect"
                   Stroke="#FF8B5CF6"
                   StrokeThickness="2"
                   Fill="#338B5CF6"
                   Visibility="Collapsed" />
        <TextBlock x:Name="HintText"
                   Foreground="White"
                   FontFamily="Segoe UI Variable Display"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Canvas.Left="24" Canvas.Top="24"
                   Text="Drag a rectangle around the HUD element you want OCR to read.  ESC = cancel." />
        <TextBlock x:Name="CoordsText"
                   Foreground="#FFE0E0FF"
                   FontFamily="Cascadia Mono,Consolas"
                   FontSize="13"
                   Canvas.Left="24" Canvas.Top="52" />
    </Canvas>
</Window>
