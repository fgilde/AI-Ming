<visuality:BaseDialog x:Class="PowerAim.Visuality.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PowerAim.Visuality"
        xmlns:converter="clr-namespace:PowerAim.Converter"
        xmlns:mdXaml="https://github.com/whistyun/MdXaml"
        xmlns:visuality="clr-namespace:PowerAim.Visuality"
        mc:Ignorable="d"
        Title="Update"
        Height="440"
        Closing="UpdateDialog_OnClosing"
        Width="540"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="False"
        Background="{StaticResource FluentSurface1}">
    <Window.Resources>
        <converter:AddConverter x:Key="AddConverter" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="&#xE896;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           Foreground="{DynamicResource FluentAccent}"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="TitleLabel"
                           Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='UpdateAvailable'}"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="13" />
            </StackPanel>
            <TextBlock x:Name="HeaderLabel"
                       Text="{Binding Header}"
                       Margin="0,0,72,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource FluentTextSecondary}"
                       FontFamily="Segoe UI Variable Small"
                       FontSize="11" />
            <Button IsEnabled="{Binding CanClose}"
                    x:Name="Exit"
                    Content="&#xE8BB;"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Width="46"
                    Height="40"
                    Padding="0"
                    FontSize="10"
                    VerticalAlignment="Top"
                    Click="Exit_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Body -->
        <Border Grid.Row="1" Style="{StaticResource FluentCard}" Margin="14,8,14,8" Padding="14">
            <Grid x:Name="ReleaseInfo">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='YourVersion'}" />
                    <TextBlock Foreground="{DynamicResource FluentTextPrimary}"
                               FontFamily="Segoe UI Variable Text"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="4,0,0,0"
                               Text="{Binding CurrentVersion}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="1">
                    <TextBlock Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='NewVersion'}" />
                    <TextBlock Foreground="{DynamicResource FluentAccent}"
                               FontFamily="Segoe UI Variable Text"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="4,0,0,0"
                               Text="{Binding NewVersion}" />
                </StackPanel>
                <mdXaml:MarkdownScrollViewer Grid.Row="2"
                                             Margin="0,8,0,0"
                                             MarkdownStyle="{StaticResource MdStyle}"
                                             Markdown="{Binding Description}"
                                             Foreground="{StaticResource FluentTextPrimary}"
                                             xml:space="preserve" />
            </Grid>
        </Border>

        <!-- Progress -->
        <Grid Grid.Row="2" Margin="14,0,14,4">
            <ProgressBar Maximum="100" Minimum="0" IsIndeterminate="false"
                         Visibility="Hidden"
                         Foreground="{DynamicResource FluentAccent}"
                         Background="{DynamicResource FluentSurface3}"
                         BorderThickness="0"
                         Value="0"
                         VerticalAlignment="Top"
                         x:Name="UpdateProgressBar"
                         Margin="0,0,0,4"
                         Height="4" />
            <TextBlock FontSize="11"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource FluentTextSecondary}"
                       FontFamily="Segoe UI Variable Small"
                       Margin="0,6,0,0"
                       Text="{Binding Status}" />
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,14,14">
            <Button x:Name="CancelButton"
                    IsEnabled="{Binding CanClose}"
                    Style="{StaticResource FluentStandardButton}"
                    Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Cancel'}"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Click="Exit_Click" />
            <Button x:Name="ApplyButton"
                    IsEnabled="{Binding CanClose}"
                    Style="{StaticResource FluentAccentButton}"
                    Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='InstallUpdate'}"
                    MinWidth="120"
                    Click="Confirm_Click" />
        </StackPanel>
    </Grid>
</visuality:BaseDialog>
