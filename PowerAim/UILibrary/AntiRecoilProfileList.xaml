<UserControl x:Class="PowerAim.UILibrary.AntiRecoilProfileList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
             xmlns:poweraim="clr-namespace:PowerAim"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderThickness="0" Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ListBox
                x:Name="ProfilesList"
                ItemsSource="{Binding Profiles, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Foreground="{DynamicResource FluentTextPrimary}"
                FontFamily="Segoe UI Variable Text"
                Margin="0"
                Padding="2"
                HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock Text="{Binding Name}"
                                           ToolTip="{Binding Description}"
                                           Foreground="{DynamicResource FluentTextPrimary}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Foreground="{DynamicResource FluentTextSecondary}"
                                           FontFamily="Segoe UI Variable Small"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding Description}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <!-- Per-profile hotkey: pressing the bound key toggles this profile's
                                     active state (radio: if it's currently active, clears active; otherwise
                                     sets it). Same UI shape as the Mapping profile list. The keybind is
                                     persisted by AKeyChanger into BindingSettings under
                                     ANTIRECOIL_PROFILE_<id>. -->
                                <uiLibrary:AKeyChanger KeyConfigName="{Binding Id}"
                                                       Tag="{Binding}"
                                                       KeyConfigPrefix="ANTIRECOIL_PROFILE"
                                                       BindingManager="{Binding DataContext.BindingManager, RelativeSource={RelativeSource AncestorType=poweraim:MainWindow}}"
                                                       MouseDown="SwallowMouse"
                                                       GlobalKeyPressed="ApplyBindingActive"
                                                       WithBorder="False"
                                                       Text="" />
                                <!-- Toggle = is this profile currently THE active one. Bound to a
                                     writable shim (IsActiveSelfWrite) so flipping it routes through
                                     the profile manager and deactivates any sibling. -->
                                <uiLibrary:AToggle BorderBrush="Transparent" Text=""
                                                   Checked="{Binding IsActiveSelfWrite, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True}" />
                                <Button Style="{StaticResource FluentIconButton}"
                                    ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Edit'}"
                                    Tag="{Binding}"
                                    MouseDown="SwallowMouse"
                                    Click="EditProfile_Click"
                                    Foreground="{DynamicResource FluentTextPrimary}"
                                    Content="&#xEB7E;"
                                    Padding="0,0,0,0"
                                    FontSize="20"
                                    Width="50" />
                                <Button Style="{StaticResource FluentIconButton}"
                                    ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Delete'}"
                                    Tag="{Binding}"
                                    MouseDown="SwallowMouse"
                                    Click="DeleteProfile_Click"
                                    Foreground="{DynamicResource FluentTextPrimary}"
                                    Content="&#xE74D;"
                                    Padding="0,0,0,0"
                                    FontSize="20"
                                    Width="50" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Grid.Row="1">
                <Button Style="{StaticResource FluentIconButton}"
                    HorizontalAlignment="Right"
                    ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AntiRecoilAddProfile'}"
                    MouseDown="SwallowMouse"
                    Click="AddProfile_Click"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    Content="&#xECC8;"
                    Padding="0,0,0,0"
                    FontSize="20"
                    Width="50" />
            </Border>
        </Grid>
    </Border>
</UserControl>
