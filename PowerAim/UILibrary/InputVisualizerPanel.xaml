<UserControl x:Class="PowerAim.UILibrary.InputVisualizerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             d:DesignWidth="560" d:DesignHeight="190">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Keyboard + mouse diagram (drawn in code-behind) -->
        <Canvas x:Name="KbCanvas" Grid.Column="0" Width="300" Height="180" />

        <!-- Reused Xbox controller diagram, scaled down -->
        <Viewbox Grid.Column="1" Width="250" Height="170" Margin="10,0,0,0" Stretch="Uniform">
            <local:Xbox360ControllerCanvas x:Name="Pad" Width="720" Height="330" />
        </Viewbox>
    </Grid>
</UserControl>
