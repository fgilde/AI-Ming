<UserControl x:Class="PowerAim.UILibrary.HiddenControllersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="500" d:DesignWidth="700">
    <StackPanel>
        <TextBlock x:Name="HeaderText"
                   Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='HiddenControllersHelp'}"
                   Foreground="{DynamicResource FluentTextSecondary}"
                   FontFamily="Segoe UI Variable Text"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <TextBlock x:Name="ElevationWarning"
                   Visibility="Collapsed"
                   Foreground="{DynamicResource FluentAccent}"
                   FontFamily="Segoe UI Variable Text"
                   FontWeight="SemiBold"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='NotElevatedWarning'}" />

        <StackPanel x:Name="DevicesPanel" />

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Refresh'}"
                    MinHeight="32" Padding="14,4,14,4"
                    Margin="0,0,8,0"
                    Click="Refresh_Click" />
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource FluentTextSecondary}"
                       FontFamily="Segoe UI Variable Small"
                       FontSize="11"
                       TextWrapping="Wrap" />
        </StackPanel>
    </StackPanel>
</UserControl>
