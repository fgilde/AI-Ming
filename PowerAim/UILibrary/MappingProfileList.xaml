<UserControl x:Class="PowerAim.UILibrary.MappingProfileList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
             xmlns:poweraim="clr-namespace:PowerAim"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="600">
    <Border BorderThickness="0" Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ListBox x:Name="ProfilesBox"
                     ItemsSource="{Binding Profiles}"
                     Foreground="{DynamicResource FluentTextPrimary}"
                     FontFamily="Segoe UI Variable Text"
                     Margin="0" Padding="2"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource FluentTextPrimary}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Foreground="{DynamicResource FluentTextSecondary}"
                                           FontFamily="Segoe UI Variable Small"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding MatchProcess, StringFormat=Match: {0}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <uiLibrary:AKeyChanger KeyConfigName="{Binding Id}"
                                                       Tag="{Binding}"
                                                       KeyConfigPrefix="MAPPING_PROFILE"
                                                       BindingManager="{Binding DataContext.BindingManager, RelativeSource={RelativeSource AncestorType=poweraim:MainWindow}}"
                                                       MouseDown="SwallowMouse"
                                                       GlobalKeyPressed="ApplyBindingEnabled"
                                                       WithBorder="False"
                                                       Text="" />
                                <uiLibrary:AToggle BorderBrush="Transparent" Text=""
                                                   Checked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True}" />
                                <Button Style="{StaticResource FluentIconButton}"
                                        ToolTip="Edit"
                                        Tag="{Binding}"
                                        Click="EditProfile_Click"
                                        Foreground="{DynamicResource FluentTextPrimary}"
                                        Content="&#xEB7E;"
                                        Padding="0" FontSize="20" Width="50" />
                                <Button Style="{StaticResource FluentIconButton}"
                                        ToolTip="Duplicate"
                                        Tag="{Binding}"
                                        Click="DuplicateProfile_Click"
                                        Foreground="{DynamicResource FluentTextPrimary}"
                                        Content="&#xE8C8;"
                                        Padding="0" FontSize="20" Width="50" />
                                <Button Style="{StaticResource FluentIconButton}"
                                        ToolTip="Delete"
                                        Tag="{Binding}"
                                        Click="DeleteProfile_Click"
                                        Foreground="{DynamicResource FluentTextPrimary}"
                                        Content="&#xE74D;"
                                        Padding="0" FontSize="20" Width="50" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Grid Grid.Row="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource FluentStandardButton}"
                            Content="+ FPS preset"
                            Padding="14,4,14,4"
                            MinHeight="34"
                            Margin="0,8,8,0"
                            Click="AddFpsPreset_Click" />
                    <Button Style="{StaticResource FluentAccentButton}"
                            Content="+ New profile"
                            Padding="14,4,14,4"
                            MinHeight="34"
                            Margin="0,8,0,0"
                            Click="AddBlank_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
