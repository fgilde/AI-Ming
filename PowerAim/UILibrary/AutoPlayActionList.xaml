<UserControl x:Class="UILibrary.AutoPlayActionList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:AntWpf.Controls;assembly=AntWpf"
             xmlns:local="clr-namespace:UILibrary"
             mc:Ignorable="d"
             x:Name="ThisControl"
             d:DesignHeight="300" d:DesignWidth="400">
    <Border BorderThickness="0" Background="Transparent" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ListBox
                x:Name="ActionsListBox"
                ItemsSource="{Binding Actions, ElementName=ThisControl}"
                Foreground="{DynamicResource FluentTextPrimary}"
                FontFamily="Segoe UI Variable Text"
                Margin="0"
                Padding="2"
                MinHeight="100"
                MaxHeight="200"
                HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical">
                                <TextBlock
                                    Text="{Binding Name}"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding IsValid, Converter={StaticResource boolToBrush}}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Text="{Binding DisplayText}"
                                    FontSize="10"
                                    Opacity="0.7"
                                    Foreground="{DynamicResource FluentTextSecondary}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource FluentIconButton}"
                                    ToolTip="Edit Action"
                                    Tag="{Binding}"
                                    MouseDown="UIElement_OnMouseDown"
                                    Click="EditAction_Click"
                                    Foreground="{DynamicResource FluentTextPrimary}"
                                    Content="&#xEB7E;"
                                    Padding="0"
                                    FontSize="16"
                                    Width="35" />
                                <Button Style="{StaticResource FluentIconButton}"
                                    ToolTip="Delete Action"
                                    Tag="{Binding}"
                                    MouseDown="UIElement_OnMouseDown"
                                    Click="DeleteAction_Click"
                                    Foreground="{DynamicResource FluentTextPrimary}"
                                    Content="&#xE74D;"
                                    Padding="0"
                                    FontSize="16"
                                    Width="35" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Grid.Row="1" Margin="0 5 0 0">
                <Button Style="{StaticResource FluentIconButton}"
                    HorizontalAlignment="Right"
                    ToolTip="Add Action"
                    MouseDown="UIElement_OnMouseDown"
                    Click="AddAction_Click"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    Content="&#xECC8;"
                    Padding="0"
                    FontSize="18"
                    Width="40" />
            </Border>
        </Grid>
    </Border>
</UserControl>
