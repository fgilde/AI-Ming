<UserControl x:Class="PowerAim.UILibrary.GamepadDiagnosticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="400" d:DesignWidth="600">
    <StackPanel>
        <!-- XInput slots row -->
        <TextBlock Text="XInput slots (the 4 controllers Windows tracks)"
                   Foreground="{DynamicResource FluentTextPrimary}"
                   FontFamily="Segoe UI Variable Display"
                   FontWeight="SemiBold" FontSize="13"
                   Margin="0,4,0,8" />
        <StackPanel x:Name="SlotsPanel" />

        <!-- Detected gamepads summary row + link to full subpage. The dedicated subpage gives
             more room for friendly-name + hardware-id + Hide/Show actions than this strip can. -->
        <Grid Margin="0,14,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Detected gamepads (Windows HID devices)"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold" FontSize="13" />
                <TextBlock x:Name="DeviceSummary"
                           Foreground="{DynamicResource FluentTextSecondary}"
                           FontFamily="Segoe UI Variable Small" FontSize="11"
                           Margin="0,2,0,0" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Manage hidden controllers →"
                    Padding="12,4,12,4"
                    MinHeight="30"
                    ToolTip="Opens a focused page where you can hide / unhide individual controllers without HidHide."
                    Click="OpenHiddenControllers_Click" />
        </Grid>

        <!-- Sender state -->
        <TextBlock Text="PowerAim sender"
                   Foreground="{DynamicResource FluentTextPrimary}"
                   FontFamily="Segoe UI Variable Display"
                   FontWeight="SemiBold" FontSize="13"
                   Margin="0,14,0,8" />
        <StackPanel x:Name="SenderPanel" />

        <!-- Suggestion -->
        <Border BorderBrush="{DynamicResource FluentAccent}"
                BorderThickness="0,0,0,0"
                Margin="0,14,0,4">
            <StackPanel>
                <TextBlock Text="Diagnose"
                           Foreground="{DynamicResource FluentAccent}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold" FontSize="13"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="SuggestionText"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="13"
                           TextWrapping="Wrap"
                           LineHeight="20" />
            </StackPanel>
        </Border>

        <!-- Actions -->
        <WrapPanel Margin="0,12,0,0">
            <Button Content="Fire test RT pulse"
                    MinHeight="32" Padding="12,4,12,4"
                    Margin="0,0,8,4"
                    Click="TestPulse_Click" />
            <Button Content="Reconnect virtual pad"
                    MinHeight="32" Padding="12,4,12,4"
                    Margin="0,0,8,4"
                    ToolTip="Forces a USB disconnect + reconnect of PowerAim's virtual controller. Often kicks games into picking it up when they were stuck on a different slot."
                    Click="ReconnectVirtual_Click" />
            <Button Content="Reset HidHide cloak"
                    MinHeight="32" Padding="12,4,12,4"
                    Margin="0,0,8,4"
                    ToolTip="Turns HidHide's master cloak off and unhides every device — fixes situations where past PowerAim sessions accidentally cloaked your real or virtual pads."
                    Click="ResetHidHide_Click" />
            <Button Content="Refresh now"
                    MinHeight="32" Padding="12,4,12,4"
                    Margin="0,0,8,4"
                    Click="Refresh_Click" />
            <Button x:Name="LaunchHidHideBtn"
                    Content="Launch HidHide UI"
                    MinHeight="32" Padding="12,4,12,4"
                    Margin="0,0,8,4"
                    ToolTip="Opens HidHideClient.exe if installed. Use HidHide to cloak your physical pad from games while leaving PowerAim's virtual pad visible."
                    Click="LaunchHidHide_Click" />
            <Button Content="Open Gamepad Tester"
                    MinHeight="32" Padding="12,4,12,4"
                    Margin="0,0,8,4"
                    ToolTip="Switches to the live gamepad tester page — useful for verifying physical input + slot mapping."
                    Click="OpenGamepadTester_Click" />
            <Button Content="Windows joy.cpl"
                    MinHeight="32" Padding="12,4,12,4"
                    Margin="0,0,8,4"
                    ToolTip="Opens Windows' built-in game controller properties dialog (joy.cpl)."
                    Click="OpenJoyCpl_Click" />
        </WrapPanel>
    </StackPanel>
</UserControl>
