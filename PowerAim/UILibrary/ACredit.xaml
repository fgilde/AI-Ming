<UserControl x:Class="PowerAim.UILibrary.ACredit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             d:DesignWidth="282.5"
             d:DesignHeight="46">
    <Grid>
        <Border Background="{DynamicResource FluentSurface2}"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{DynamicResource FluentStroke}"
                Margin="0,0,0,6"
                Padding="10,6,10,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Label x:Name="NameLabel"
                       Grid.Row="0"
                       FontFamily="Segoe UI Variable Text"
                       FontWeight="SemiBold"
                       Content="gilde.org"
                       Foreground="{DynamicResource FluentTextPrimary}"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       Padding="0" />
                <Label x:Name="Description"
                       Grid.Row="1"
                       FontFamily="Segoe UI Variable Small"
                       Content="Logic"
                       Foreground="{DynamicResource FluentTextSecondary}"
                       VerticalContentAlignment="Center"
                       FontSize="11"
                       Padding="0,2,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
