<UserControl x:Class="PowerAim.UILibrary.MappingEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="SectionIcon" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource FluentAccent}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style x:Key="SectionIconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource FluentAccentForeground}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SectionTitleBig" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SectionSubtitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FluentTextTertiary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Small" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,1,0,0" />
        </Style>
    </UserControl.Resources>
    <StackPanel>

        <!-- ====== Profile basics ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE74E;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Profile" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Name and active state" />
                    </StackPanel>
                    <uiLibrary:AToggle Grid.Column="2"
                                       Background="Transparent" BorderBrush="Transparent"
                                       Text="Enabled"
                                       VerticalAlignment="Center"
                                       Checked="{Binding Profile.Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBox Text="{Binding Profile.Name, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Profile name"
                         Style="{DynamicResource placeHolder}" />
            </StackPanel>
        </Border>

        <!-- ====== Match process ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE7C8;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Match process (optional)" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Only activate while a process matching the pattern is focused" />
                    </StackPanel>
                </Grid>
                <TextBox Text="{Binding Profile.MatchProcess, UpdateSourceTrigger=PropertyChanged}"
                         Tag="cs2*, valorant, *fortnite*"
                         Style="{DynamicResource placeHolder}" />
                <TextBlock Style="{DynamicResource FluentCaption}"
                           Margin="2,8,0,0"
                           TextWrapping="Wrap"
                           Text="Supports wildcards (*, ?) and pipes (cs2|valorant). Leave empty for always-on." />
            </StackPanel>
        </Border>

        <!-- ====== Mappings — the actual core editor ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE8A1;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Mappings" />
                        <TextBlock Style="{StaticResource SectionSubtitle}"
                                   Text="Click a Source / Target slot, then press the key or controller button you want to bind." />
                    </StackPanel>
                    <Button Grid.Column="2" Style="{StaticResource FluentStandardButton}"
                            Content="+ Add"
                            Padding="12,4,12,4"
                            Margin="0,0,8,0"
                            ToolTip="Add an empty mapping row. Click each side to record a key / button."
                            Click="AddRow_Click" />
                    <Button Grid.Column="3" Style="{StaticResource FluentStandardButton}"
                            Content="+ Stick → Mouse"
                            Padding="10,4,10,4"
                            Margin="0,0,8,0"
                            ToolTip="Adds the special right-stick → mouse-motion mapping."
                            Click="AddStickToMouse_Click" />
                    <Button Grid.Column="4" Style="{StaticResource FluentStandardButton}"
                            Content="+ Mouse → Stick"
                            Padding="10,4,10,4"
                            ToolTip="Adds the special mouse-motion → right-stick mapping."
                            Click="AddMouseToStick_Click" />
                </Grid>

                <!-- Header strip -->
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Margin="2,0,8,0" IsHitTestVisible="False" Opacity="0" />
                    <TextBlock Grid.Column="1"
                               Text="SOURCE"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Small"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="2,0,0,0" />
                    <TextBlock Grid.Column="2"
                               Text="→"
                               Foreground="{DynamicResource FluentTextTertiary}"
                               FontSize="16"
                               Margin="14,0,14,0"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3"
                               Text="TARGET"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Small"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="2,0,0,0" />
                    <TextBlock Grid.Column="4"
                               Text="ACTIVATOR"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Small"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="14,0,14,0" />
                </Grid>

                <ItemsControl x:Name="MappingItems" />

                <TextBlock x:Name="MappingEmpty"
                           Style="{DynamicResource FluentCaption}"
                           Text="No mappings yet. Click '+ Add' above, then click each slot to record a key or controller button." />
            </StackPanel>
        </Border>

        <!-- ====== Stick tuning ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE7C1;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Stick &amp; Motion Tuning" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Dead-zone, response curve and sensitivities for stick ↔ mouse" />
                    </StackPanel>
                </Grid>
                <StackPanel x:Name="StickSettingsHost" />
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
