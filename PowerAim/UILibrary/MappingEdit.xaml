<UserControl x:Class="PowerAim.UILibrary.MappingEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="SectionIcon" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource FluentAccent}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style x:Key="SectionIconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource FluentAccentForeground}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SectionTitleBig" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SectionSubtitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FluentTextTertiary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Small" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,1,0,0" />
        </Style>
    </UserControl.Resources>
    <StackPanel>

        <!-- ====== Profile basics ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE74E;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Profile'}" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='TriggerSubtitle'}" />
                    </StackPanel>
                    <uiLibrary:AToggle Grid.Column="2"
                                       Background="Transparent" BorderBrush="Transparent"
                                       Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Enabled'}"
                                       VerticalAlignment="Center"
                                       Checked="{Binding Profile.Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBox Text="{Binding Profile.Name, UpdateSourceTrigger=PropertyChanged}"
                         Tag="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='ProfileName'}"
                         Style="{DynamicResource placeHolder}" />
            </StackPanel>
        </Border>

        <!-- ====== Match process ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE7C8;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='MatchProcessOptional'}" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='MatchProcessActivateHint'}" />
                    </StackPanel>
                </Grid>
                <TextBox Text="{Binding Profile.MatchProcess, UpdateSourceTrigger=PropertyChanged}"
                         Tag="cs2*, valorant, *fortnite*"
                         Style="{DynamicResource placeHolder}" />
                <TextBlock Style="{DynamicResource FluentCaption}"
                           Margin="2,8,0,0"
                           TextWrapping="Wrap"
                           Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='MatchProcessWildcardHelp'}" />
            </StackPanel>
        </Border>

        <!-- ====== Mappings — the actual core editor ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE8A1;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Mappings'}" />
                        <TextBlock Style="{StaticResource SectionSubtitle}"
                                   Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='MappingsSubtitle'}" />
                    </StackPanel>
                    <Button Grid.Column="2" Style="{StaticResource FluentStandardButton}"
                            Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='AddRow'}"
                            Padding="12,4,12,4"
                            Margin="0,0,8,0"
                            ToolTip="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='AddRowTooltip'}"
                            Click="AddRow_Click" />
                    <Button Grid.Column="3" Style="{StaticResource FluentStandardButton}"
                            Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='AddStickToMouse'}"
                            Padding="10,4,10,4"
                            Margin="0,0,8,0"
                            ToolTip="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='AddStickToMouseTooltip'}"
                            Click="AddStickToMouse_Click" />
                    <Button Grid.Column="4" Style="{StaticResource FluentStandardButton}"
                            Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='AddMouseToStick'}"
                            Padding="10,4,10,4"
                            ToolTip="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='AddMouseToStickTooltip'}"
                            Click="AddMouseToStick_Click" />
                </Grid>

                <!-- Header strip -->
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Margin="2,0,8,0" IsHitTestVisible="False" Opacity="0" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='SourceHeader'}"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Small"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="2,0,0,0" />
                    <TextBlock Grid.Column="2"
                               Text="→"
                               Foreground="{DynamicResource FluentTextTertiary}"
                               FontSize="16"
                               Margin="14,0,14,0"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='TargetHeader'}"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Small"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="2,0,0,0" />
                    <TextBlock Grid.Column="4"
                               Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='ActivatorHeader'}"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Small"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="14,0,14,0" />
                </Grid>

                <ItemsControl x:Name="MappingItems" />

                <TextBlock x:Name="MappingEmpty"
                           Style="{DynamicResource FluentCaption}"
                           Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='NoMappingsYet'}" />
            </StackPanel>
        </Border>

        <!-- ====== Stick tuning ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE7C1;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='StickMotionTuning'}" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='StickTuningSubtitle'}" />
                    </StackPanel>
                </Grid>
                <StackPanel x:Name="StickSettingsHost" />
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
