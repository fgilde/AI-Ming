<UserControl x:Class="PowerAim.UILibrary.MappingEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PowerAim.UILibrary"
             xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="SectionIcon" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource FluentAccent}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style x:Key="SectionIconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource FluentAccentForeground}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SectionTitleBig" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SectionSubtitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FluentTextTertiary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Small" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,1,0,0" />
        </Style>
    </UserControl.Resources>
    <StackPanel>

        <!-- ====== Profile basics ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE74E;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Profile" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Name and active state" />
                    </StackPanel>
                    <uiLibrary:AToggle Grid.Column="2"
                                       Background="Transparent" BorderBrush="Transparent"
                                       Text="Enabled"
                                       VerticalAlignment="Center"
                                       Checked="{Binding Profile.Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBox Text="{Binding Profile.Name, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Profile name"
                         Style="{DynamicResource placeHolder}" />
            </StackPanel>
        </Border>

        <!-- ====== Match process ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE7C8;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Match process (optional)" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Only activate while a process matching the pattern is focused" />
                    </StackPanel>
                </Grid>
                <TextBox Text="{Binding Profile.MatchProcess, UpdateSourceTrigger=PropertyChanged}"
                         Tag="cs2*, valorant, *fortnite*"
                         Style="{DynamicResource placeHolder}" />
                <TextBlock Style="{DynamicResource FluentCaption}"
                           Margin="2,8,0,0"
                           TextWrapping="Wrap"
                           Text="Supports wildcards (*, ?) and pipes (cs2|valorant). Leave empty for always-on." />
            </StackPanel>
        </Border>

        <!-- ====== Stick configuration ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE7C1;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Stick &amp; Motion Tuning" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Dead-zone, response curve and sensitivities for stick ↔ mouse" />
                    </StackPanel>
                </Grid>
                <StackPanel x:Name="StickSettingsHost" />
            </StackPanel>
        </Border>

        <!-- ====== Controller visual ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE7FC;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Xbox 360 Controller" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Click a button to start a mapping — then click a key on the keyboard below." />
                    </StackPanel>
                </Grid>
                <Border Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <local:Xbox360ControllerCanvas x:Name="Controller" HorizontalAlignment="Center" />
                </Border>
            </StackPanel>
        </Border>

        <!-- ====== Keyboard + Mouse visual ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE765;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Keyboard &amp; Mouse" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="The other side of the mapping. ESC cancels an armed selection." />
                    </StackPanel>
                </Grid>
                <Border Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <StackPanel x:Name="KeyboardStack" HorizontalAlignment="Center" />
                </Border>
            </StackPanel>
        </Border>

        <!-- ====== Mappings list ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE8A1;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Mappings" />
                        <TextBlock x:Name="StatusText" Style="{StaticResource SectionSubtitle}"
                                   Text="Click a controller button or a key to start." />
                    </StackPanel>
                    <Button Grid.Column="2" Style="{StaticResource FluentStandardButton}"
                            Content="Stick → Mouse"
                            Padding="10,4,10,4"
                            Margin="0,0,8,0"
                            ToolTip="Add a mapping that feeds the right stick into mouse motion."
                            Click="AddStickToMouse_Click" />
                    <Button Grid.Column="3" Style="{StaticResource FluentStandardButton}"
                            Content="Mouse → Stick"
                            Padding="10,4,10,4"
                            ToolTip="Add a mapping that feeds mouse motion into the virtual right stick."
                            Click="AddMouseToStick_Click" />
                </Grid>
                <ItemsControl x:Name="MappingItems" />
                <TextBlock x:Name="MappingEmpty"
                           Style="{DynamicResource FluentCaption}"
                           Text="No mappings yet. Click a controller button to arm a source, then click a key to pair it." />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
