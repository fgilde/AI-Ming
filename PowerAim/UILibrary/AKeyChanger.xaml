<UserControl x:Class="PowerAim.UILibrary.AKeyChanger"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PowerAim.UILibrary"
             Loaded="AKeyChanger_OnLoaded"
             mc:Ignorable="d"
             d:DesignWidth="282.5"
             d:DesignHeight="40">
    <Border x:Name="MainBorder"
            BorderThickness="0"
            Height="40">
        <Grid x:Name="MainGrid" PreviewMouseRightButtonUp="ContextMenu_OnOpened">
            <Grid.ContextMenu>
                <ContextMenu Name="ContextMenu">
                    <MenuItem Header="Delete Binding" Click="DeleteBinding_Click" />
                </ContextMenu>
            </Grid.ContextMenu>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Background="Transparent">
                <Grid>
                    <Label x:Name="KeyChangerTitle"
                           Padding="2,10,10,10"
                           FontFamily="Segoe UI Variable Text"
                           Content="Change Aim Keybind"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           VerticalContentAlignment="Center"
                           FontSize="13" />

                    <Border HorizontalAlignment="Right"
                            Margin="5,7,2,7"
                            BorderBrush="{DynamicResource FluentStroke}"
                            BorderThickness="1"
                            Background="{DynamicResource FluentSurface3}"
                            CornerRadius="6"
                            MinWidth="70">
                        <Grid>
                            <TextBlock x:Name="KeyDeviceInfo"
                                       Visibility="Collapsed"
                                       Text="&#xE7FC;"
                                       Background="Transparent"
                                       Foreground="{DynamicResource FluentTextSecondary}"
                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       Margin="-10,-8,0,0"
                                       FontSize="16"
                                       VerticalAlignment="Top" />
                            <Label x:Name="KeyNotifierLabel"
                                   FontFamily="Segoe UI Variable Small"
                                   Content="Right"
                                   FontSize="12"
                                   HorizontalContentAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Padding="10,2,10,2"
                                   Foreground="{DynamicResource FluentTextPrimary}" />
                        </Grid>
                    </Border>

                    <Button x:Name="Reader"
                            PreviewMouseLeftButtonDown="Reader_OnClick"
                            Background="Transparent"
                            BorderBrush="{x:Null}"
                            Padding="0"
                            Cursor="Hand"
                            Margin="0" />
                </Grid>
            </Border>

            <Label Grid.Column="1"
                   Visibility="{Binding ShowTimeEdit, RelativeSource={RelativeSource AncestorType=local:AKeyChanger}, Converter={StaticResource boolToVis}}"
                   Content="&#xec92;"
                   Cursor="Hand"
                   Background="Transparent"
                   Foreground="{Binding HasTimeValue, RelativeSource={RelativeSource AncestorType=local:AKeyChanger}, Converter={StaticResource boolToBrush}}"
                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                   ToolTip="Configure min time"
                   FontSize="11"
                   Margin="-6,10,4,0"
                   HorizontalAlignment="Right"
                   MouseLeftButtonUp="ConfigureMinTimeLabel_OnClick"
                   VerticalAlignment="Center" />

            <Popup x:Name="TimeSliderPopup"
                   Placement="Mouse"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        CornerRadius="8"
                        MinWidth="330"
                        MinHeight="130"
                        BorderThickness="1"
                        Padding="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.3" />
                    </Border.Effect>
                    <local:ASlider x:Name="MinTimeSlider"
                                   BorderBrush="Transparent"
                                   Background="Transparent"
                                   ValueChanged="MinTimeSlider_OnValueChanged"
                                   Steps="0.1"
                                   TickFrequency="0.01"
                                   Maximum="5"
                                   Minimum="0" />
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
