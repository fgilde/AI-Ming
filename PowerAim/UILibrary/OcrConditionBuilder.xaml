<UserControl x:Class="PowerAim.UILibrary.OcrConditionBuilder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="480" d:DesignHeight="200">
    <!-- Recursive editor for an OcrConditionGroup. The entire body — operator chip, child rows,
         add buttons — is built in code-behind so we can mix leaf rows and nested
         OcrConditionBuilders without an unwieldy nested DataTemplate hierarchy. -->
    <Border x:Name="RootBorder"
            BorderBrush="{DynamicResource FluentStroke}"
            BorderThickness="1"
            CornerRadius="6"
            Background="Transparent"
            Padding="10,8,10,8">
        <StackPanel x:Name="Root" />
    </Border>
</UserControl>
