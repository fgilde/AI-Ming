<UserControl x:Class="PowerAim.UILibrary.GamepadTesterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="780">
    <UserControl.Resources>
        <Style x:Key="GamepadButtonIndicator" TargetType="Border">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="BorderBrush" Value="{DynamicResource FluentStroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Background" Value="{DynamicResource FluentSurface3}" />
        </Style>
        <Style x:Key="GamepadButtonLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Small" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SubHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FluentTextSecondary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: Back button + title + connection status -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    x:Name="BackButton"
                    Style="{StaticResource FluentStandardButton}"
                    Click="BackButton_Click"
                    Padding="10,6,12,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72B;"
                               FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Back'}"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13" />
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1"
                       Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='GamepadControllerTest'}"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center"
                       FontFamily="Segoe UI Variable Display"
                       FontWeight="SemiBold"
                       FontSize="18"
                       Foreground="{DynamicResource FluentTextPrimary}" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Border CornerRadius="14"
                        Background="{DynamicResource FluentSurface3}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        Padding="10,4,12,4"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#E81123" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="ConnectionStatus"
                                   Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Disconnected'}"
                                   FontFamily="Segoe UI Variable Small"
                                   FontSize="12"
                                   Foreground="{DynamicResource FluentTextPrimary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Button x:Name="PopOutButton"
                        Style="{StaticResource FluentStandardButton}"
                        Click="PopOut_Click"
                        Padding="10,6,12,6"
                        ToolTip="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='PopOutTooltip'}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A7;"
                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='PopOut'}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Layout: D-Pad / Center / Face Buttons in a card -->
                <Border Style="{StaticResource FluentCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- D-Pad -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='DPad'}" Style="{StaticResource SubHeader}" />
                            <Grid Width="170" Height="170">
                                <Border x:Name="BtnUp" Style="{StaticResource GamepadButtonIndicator}" HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <TextBlock Text="↑" Style="{StaticResource GamepadButtonLabel}" />
                                </Border>
                                <Border x:Name="BtnRight" Style="{StaticResource GamepadButtonIndicator}" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="→" Style="{StaticResource GamepadButtonLabel}" />
                                </Border>
                                <Border x:Name="BtnDown" Style="{StaticResource GamepadButtonIndicator}" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                    <TextBlock Text="↓" Style="{StaticResource GamepadButtonLabel}" />
                                </Border>
                                <Border x:Name="BtnLeft" Style="{StaticResource GamepadButtonIndicator}" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="←" Style="{StaticResource GamepadButtonLabel}" />
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Center -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Center'}" Style="{StaticResource SubHeader}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border x:Name="BtnBack" Style="{StaticResource GamepadButtonIndicator}">
                                    <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Back'}" Style="{StaticResource GamepadButtonLabel}" FontSize="10" />
                                </Border>
                                <Border x:Name="BtnStart" Style="{StaticResource GamepadButtonIndicator}">
                                    <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Start'}" Style="{StaticResource GamepadButtonLabel}" FontSize="10" />
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <StackPanel>
                                    <Border x:Name="BtnLS" Style="{StaticResource GamepadButtonIndicator}" HorizontalAlignment="Center">
                                        <TextBlock Text="LS" Style="{StaticResource GamepadButtonLabel}" />
                                    </Border>
                                    <TextBlock x:Name="LeftThumbstickValue" Text="0, 0" Style="{StaticResource GamepadButtonLabel}" FontSize="11" Foreground="{DynamicResource FluentTextSecondary}" />
                                </StackPanel>
                                <StackPanel>
                                    <Border x:Name="BtnRS" Style="{StaticResource GamepadButtonIndicator}" HorizontalAlignment="Center">
                                        <TextBlock Text="RS" Style="{StaticResource GamepadButtonLabel}" />
                                    </Border>
                                    <TextBlock x:Name="RightThumbstickValue" Text="0, 0" Style="{StaticResource GamepadButtonLabel}" FontSize="11" Foreground="{DynamicResource FluentTextSecondary}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Face buttons -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='FaceButtons'}" Style="{StaticResource SubHeader}" />
                            <Grid Width="170" Height="170">
                                <Border x:Name="BtnY" Style="{StaticResource GamepadButtonIndicator}" HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <TextBlock Text="Y" Style="{StaticResource GamepadButtonLabel}" />
                                </Border>
                                <Border x:Name="BtnB" Style="{StaticResource GamepadButtonIndicator}" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="B" Style="{StaticResource GamepadButtonLabel}" />
                                </Border>
                                <Border x:Name="BtnA" Style="{StaticResource GamepadButtonIndicator}" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                    <TextBlock Text="A" Style="{StaticResource GamepadButtonLabel}" />
                                </Border>
                                <Border x:Name="BtnX" Style="{StaticResource GamepadButtonIndicator}" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="X" Style="{StaticResource GamepadButtonLabel}" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Shoulders + Triggers -->
                <Border Style="{StaticResource FluentCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='ShouldersAndTriggers'}" Style="{StaticResource SubHeader}" HorizontalAlignment="Left" Margin="0,0,0,10" />

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" x:Name="BtnLB" Style="{StaticResource GamepadButtonIndicator}" Width="56">
                                    <TextBlock Text="LB" Style="{StaticResource GamepadButtonLabel}" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='LeftTrigger'}" FontFamily="Segoe UI Variable Small" FontSize="11" Foreground="{DynamicResource FluentTextSecondary}" />
                                    <ProgressBar x:Name="LeftTriggerBar" Height="6" Minimum="0" Maximum="255" Value="0" Foreground="{DynamicResource FluentAccent}" Background="{DynamicResource FluentSurface3}" BorderThickness="0" Margin="0,4,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" x:Name="LeftTriggerValue" Text="0" Width="32" TextAlignment="Right" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource FluentTextSecondary}" FontFamily="Segoe UI Variable Small" FontSize="11" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" x:Name="BtnRB" Style="{StaticResource GamepadButtonIndicator}" Width="56">
                                    <TextBlock Text="RB" Style="{StaticResource GamepadButtonLabel}" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='RightTrigger'}" FontFamily="Segoe UI Variable Small" FontSize="11" Foreground="{DynamicResource FluentTextSecondary}" />
                                    <ProgressBar x:Name="RightTriggerBar" Height="6" Minimum="0" Maximum="255" Value="0" Foreground="{DynamicResource FluentAccent}" Background="{DynamicResource FluentSurface3}" BorderThickness="0" Margin="0,4,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" x:Name="RightTriggerValue" Text="0" Width="32" TextAlignment="Right" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource FluentTextSecondary}" FontFamily="Segoe UI Variable Small" FontSize="11" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Sequence Testing -->
                <Border Style="{StaticResource FluentCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='SequenceTesting'}" Style="{StaticResource SubHeader}" HorizontalAlignment="Left" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='DelayBeforeStart'}" VerticalAlignment="Center" Margin="0,5,10,5" Foreground="{DynamicResource FluentTextPrimary}" FontFamily="Segoe UI Variable Text" FontSize="13" />
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="TimeoutSlider" Minimum="0" Maximum="10" Value="3" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="TimeoutValue" Text="3s" VerticalAlignment="Center" TextAlignment="Right" Foreground="{DynamicResource FluentTextSecondary}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='TestSequence'}" VerticalAlignment="Center" Margin="0,8,10,5" Foreground="{DynamicResource FluentTextPrimary}" FontFamily="Segoe UI Variable Text" FontSize="13" />
                            <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" x:Name="SequenceSelector" Margin="0,8,0,5" SelectionChanged="SequenceSelector_SelectionChanged">
                                <ComboBoxItem Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='SeqAButtonPress'}" Tag="A_Button" />
                                <ComboBoxItem Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='SeqABCombo'}" Tag="AB_Combo" />
                                <ComboBoxItem Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='SeqDpadCircle'}" Tag="DPad_Circle" IsSelected="True" />
                                <ComboBoxItem Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='SeqLStickCircle'}" Tag="LStick_Circle" />
                                <ComboBoxItem Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='SeqTriggerPress'}" Tag="Trigger_Press" />
                                <ComboBoxItem Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='SeqComplexCombo'}" Tag="Complex_Combo" />
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.ColumnSpan="3" x:Name="SequenceDescription"
                                       Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='SeqDpadCircleDescription'}"
                                       Foreground="{DynamicResource FluentTextTertiary}"
                                       FontFamily="Segoe UI Variable Small"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="StopSequenceButton"
                                    Style="{StaticResource FluentStandardButton}"
                                    Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Stop'}"
                                    MinWidth="90"
                                    Margin="0,0,8,0"
                                    IsEnabled="False"
                                    Click="StopSequenceButton_Click" />
                            <Button x:Name="StartSequenceButton"
                                    Style="{StaticResource FluentAccentButton}"
                                    Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='StartTestSequence'}"
                                    MinWidth="150"
                                    Click="StartSequenceButton_Click" />
                        </StackPanel>
                        <TextBlock x:Name="SequenceStatus" Text="" Margin="0,8,0,0" Foreground="{DynamicResource FluentAccent}" FontFamily="Segoe UI Variable Small" FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Footer actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,4,0,0">
                    <Button x:Name="RefreshButton"
                            Style="{StaticResource FluentStandardButton}"
                            Click="RefreshButton_Click"
                            Padding="12,6,12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='RefreshConnection'}" Margin="6,0,0,0" VerticalAlignment="Center" FontFamily="Segoe UI Variable Text" FontSize="13" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
