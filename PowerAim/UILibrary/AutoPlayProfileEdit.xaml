<UserControl x:Class="UILibrary.AutoPlayProfileEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
             xmlns:local="clr-namespace:UILibrary"
             mc:Ignorable="d"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch"
             d:DesignHeight="600" d:DesignWidth="500">
    <Grid Margin="5">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Stretch">
                <!-- Enabled Toggle -->
                <Grid>
                    <uiLibrary:AToggle Margin="0 -10 -8 0" Panel.ZIndex="10" BorderBrush="Transparent" Background="Transparent"
                                       Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Enabled'}"
                                       VerticalAlignment="Top" HorizontalAlignment="Right"
                                       Checked="{Binding Profile.Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel>
                        <!-- Profile Name -->
                        <Label Foreground="{StaticResource Foreground}"
                               FontSize="13"
                               Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='ProfileName'}"
                               FontFamily="Segoe UI Variable Text" />
                        <TextBox BorderThickness="1"
                                 Padding="3 5 1 5"
                                 Text="{Binding Profile.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 Margin="2, 5"
                                 Tag="{Binding Converter={StaticResource localeConverter}, ConverterParameter='EnterProfileName'}"
                                 VerticalAlignment="Top"
                                 FontFamily="Segoe UI Variable Text"
                                 Style="{DynamicResource placeHolder}"
                                 BorderBrush="{DynamicResource FluentStroke}"
                                 Background="Transparent"
                                 Foreground="{StaticResource Foreground}" />
                    </StackPanel>
                </Grid>

                <!-- Per-profile opt-out for the Ollama strategic layer. When off, AutoPlay runs
                     purely on heuristics + OCR cues — no HTTP polling, no screenshot capture for
                     the LLM, no Ollama install required. Disables the model picker below. -->
                <uiLibrary:AToggle Margin="0,15,0,0"
                                   BorderBrush="Transparent" Background="Transparent"
                                   Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AutoPlayUseOllama'}"
                                   ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AutoPlayUseOllamaHint'}"
                                   Checked="{Binding Profile.UseOllama, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Foreground="{StaticResource Foreground}"
                           FontSize="11"
                           Margin="2,0,0,4"
                           TextWrapping="Wrap"
                           Visibility="{Binding Converter={StaticResource helpVis}}"
                           Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AutoPlayUseOllamaHint'}"
                           FontFamily="Segoe UI Variable Text" />

                <!-- Ollama Model — editable ComboBox so the user can either pick from the locally
                     installed list (loaded async from /api/tags) or type any model name. The Pull
                     button next to it fetches whatever's in the box from the Ollama registry,
                     streaming progress into the line below. -->
                <StackPanel x:Name="OllamaModelPanel" Margin="0 10 0 0"
                            IsEnabled="{Binding Profile.UseOllama}">
                    <Label Foreground="{StaticResource Foreground}"
                           FontSize="13"
                           Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='OllamaModel'}"
                           FontFamily="Segoe UI Variable Text" />
                    <Grid Margin="2,5,2,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ModelCombo"
                                  Grid.Column="0"
                                  IsEditable="True"
                                  Text="{Binding Profile.OllamaModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource FluentStroke}"
                                  Padding="3,5,1,5"
                                  FontFamily="Segoe UI Variable Text"
                                  Foreground="{StaticResource Foreground}" />
                        <Button Grid.Column="1"
                                x:Name="PullModelButton"
                                Margin="6,0,0,0"
                                Padding="12,4,12,4"
                                MinHeight="28"
                                Style="{DynamicResource FluentStandardButton}"
                                ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='OllamaPullModelTooltip'}"
                                Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='OllamaPullModel'}"
                                Click="PullModel_Click" />
                    </Grid>
                    <TextBlock x:Name="PullStatusText"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontSize="11"
                               Margin="2,4,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               FontFamily="Segoe UI Variable Small" />
                    <TextBlock Foreground="{StaticResource Foreground}"
                               FontSize="11"
                               Margin="2 4 0 10"
                               TextWrapping="Wrap"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='OllamaModelRecommended'}"
                               Visibility="{Binding Converter={StaticResource helpVis}}"
                               FontFamily="Segoe UI Variable Text" />
                </StackPanel>

                <!-- Match Process (per-game auto-switch) -->
                <StackPanel Margin="0 10 0 0">
                    <Label Foreground="{StaticResource Foreground}"
                           FontSize="13"
                           Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='MatchProcessOptional'}"
                           FontFamily="Segoe UI Variable Text" />
                    <TextBox BorderThickness="1"
                             Padding="3 5 1 5"
                             Text="{Binding Profile.MatchProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="2, 5"
                             Tag="cs2*, valorant, *fortnite*"
                             FontFamily="Segoe UI Variable Text"
                             Style="{DynamicResource placeHolder}"
                             BorderBrush="{DynamicResource FluentStroke}"
                             Background="Transparent"
                             Foreground="{StaticResource Foreground}" />
                    <TextBlock Foreground="{StaticResource Foreground}"
                               FontSize="11"
                               Margin="2 0 0 10"
                               TextWrapping="Wrap"
                               Visibility="{Binding Converter={StaticResource helpVis}}"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AutoPlayMatchProcessHelp'}"
                               FontFamily="Segoe UI Variable Text" />
                </StackPanel>

                <!-- Decision Interval -->
                <StackPanel x:Name="DecisionIntervalPanel" Margin="0 5 0 0" />

                <!-- Game Context -->
                <StackPanel Margin="0 10 0 0">
                    <Label Foreground="{StaticResource Foreground}"
                           FontSize="13"
                           Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='GameContext'}"
                           FontFamily="Segoe UI Variable Text" />
                    <TextBox BorderThickness="1"
                             Padding="3 5 1 5"
                             Text="{Binding Profile.GameContext, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="80"
                             MaxHeight="150"
                             VerticalScrollBarVisibility="Auto"
                             Margin="2, 5"
                             Tag="{Binding Converter={StaticResource localeConverter}, ConverterParameter='DescribeGameForAi'}"
                             FontFamily="Segoe UI Variable Text"
                             Style="{DynamicResource placeHolder}"
                             BorderBrush="{DynamicResource FluentStroke}"
                             Background="Transparent"
                             Foreground="{StaticResource Foreground}" />
                    <TextBlock Foreground="{StaticResource Foreground}"
                               FontSize="11"
                               Margin="2 0 0 10"
                               TextWrapping="Wrap"
                               Visibility="{Binding Converter={StaticResource helpVis}}"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='GameContextExample'}"
                               FontFamily="Segoe UI Variable Text" />
                </StackPanel>

                <uiLibrary:Line Margin="0 10 0 10" />

                <!-- Actions -->
                <StackPanel>
                    <Label Foreground="{StaticResource Foreground}"
                           FontSize="13"
                           Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Actions'}"
                           FontFamily="Segoe UI Variable Text" />
                    <TextBlock Foreground="{StaticResource Foreground}"
                               FontSize="11"
                               Margin="2 0 0 10"
                               TextWrapping="Wrap"
                               Visibility="{Binding Converter={StaticResource helpVis}}"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='ActionsHelp'}"
                               FontFamily="Segoe UI Variable Text" />
                    <local:AutoPlayActionList x:Name="ActionsList"
                                              Actions="{Binding Profile.Actions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
