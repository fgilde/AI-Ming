<UserControl x:Class="UILibrary.AutoPlayProfileEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
             xmlns:local="clr-namespace:UILibrary"
             mc:Ignorable="d"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch"
             d:DesignHeight="600" d:DesignWidth="500">
    <Grid Margin="5">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Stretch">
                <!-- Enabled Toggle -->
                <Grid>
                    <uiLibrary:AToggle Margin="0 -10 -8 0" Panel.ZIndex="10" BorderBrush="Transparent" Background="Transparent"
                                       Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Enabled'}"
                                       VerticalAlignment="Top" HorizontalAlignment="Right"
                                       Checked="{Binding Profile.Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel>
                        <!-- Profile Name -->
                        <Label Foreground="{StaticResource Foreground}"
                               FontSize="13"
                               Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='ProfileName'}"
                               FontFamily="Segoe UI Variable Text" />
                        <TextBox BorderThickness="1"
                                 Padding="3 5 1 5"
                                 Text="{Binding Profile.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 Margin="2, 5"
                                 Tag="{Binding Converter={StaticResource localeConverter}, ConverterParameter='EnterProfileName'}"
                                 VerticalAlignment="Top"
                                 FontFamily="Segoe UI Variable Text"
                                 Style="{DynamicResource placeHolder}"
                                 BorderBrush="{DynamicResource FluentStroke}"
                                 Background="Transparent"
                                 Foreground="{StaticResource Foreground}" />
                    </StackPanel>
                </Grid>

                <!-- Ollama Model -->
                <StackPanel x:Name="OllamaModelPanel" Margin="0 10 0 0">
                    <Label Foreground="{StaticResource Foreground}"
                           FontSize="13"
                           Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='OllamaModel'}"
                           FontFamily="Segoe UI Variable Text" />
                    <TextBox BorderThickness="1"
                             Padding="3 5 1 5"
                             Text="{Binding Profile.OllamaModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="2, 5"
                             Tag="moondream, llava:7b, qwen2.5-vl:7b..."
                             FontFamily="Segoe UI Variable Text"
                             Style="{DynamicResource placeHolder}"
                             BorderBrush="{DynamicResource FluentStroke}"
                             Background="Transparent"
                             Foreground="{StaticResource Foreground}" />
                    <TextBlock Foreground="{StaticResource Foreground}"
                               FontSize="11"
                               Margin="2 0 0 10"
                               TextWrapping="Wrap"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='OllamaModelRecommended'}"
                               Visibility="{Binding Converter={StaticResource helpVis}}"
                               FontFamily="Segoe UI Variable Text" />
                </StackPanel>

                <!-- Match Process (per-game auto-switch) -->
                <StackPanel Margin="0 10 0 0">
                    <Label Foreground="{StaticResource Foreground}"
                           FontSize="13"
                           Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='MatchProcessOptional'}"
                           FontFamily="Segoe UI Variable Text" />
                    <TextBox BorderThickness="1"
                             Padding="3 5 1 5"
                             Text="{Binding Profile.MatchProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="2, 5"
                             Tag="cs2*, valorant, *fortnite*"
                             FontFamily="Segoe UI Variable Text"
                             Style="{DynamicResource placeHolder}"
                             BorderBrush="{DynamicResource FluentStroke}"
                             Background="Transparent"
                             Foreground="{StaticResource Foreground}" />
                    <TextBlock Foreground="{StaticResource Foreground}"
                               FontSize="11"
                               Margin="2 0 0 10"
                               TextWrapping="Wrap"
                               Visibility="{Binding Converter={StaticResource helpVis}}"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AutoPlayMatchProcessHelp'}"
                               FontFamily="Segoe UI Variable Text" />
                </StackPanel>

                <!-- Decision Interval -->
                <StackPanel x:Name="DecisionIntervalPanel" Margin="0 5 0 0" />

                <!-- Game Context -->
                <StackPanel Margin="0 10 0 0">
                    <Label Foreground="{StaticResource Foreground}"
                           FontSize="13"
                           Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='GameContext'}"
                           FontFamily="Segoe UI Variable Text" />
                    <TextBox BorderThickness="1"
                             Padding="3 5 1 5"
                             Text="{Binding Profile.GameContext, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="80"
                             MaxHeight="150"
                             VerticalScrollBarVisibility="Auto"
                             Margin="2, 5"
                             Tag="{Binding Converter={StaticResource localeConverter}, ConverterParameter='DescribeGameForAi'}"
                             FontFamily="Segoe UI Variable Text"
                             Style="{DynamicResource placeHolder}"
                             BorderBrush="{DynamicResource FluentStroke}"
                             Background="Transparent"
                             Foreground="{StaticResource Foreground}" />
                    <TextBlock Foreground="{StaticResource Foreground}"
                               FontSize="11"
                               Margin="2 0 0 10"
                               TextWrapping="Wrap"
                               Visibility="{Binding Converter={StaticResource helpVis}}"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='GameContextExample'}"
                               FontFamily="Segoe UI Variable Text" />
                </StackPanel>

                <uiLibrary:Line Margin="0 10 0 10" />

                <!-- Actions -->
                <StackPanel>
                    <Label Foreground="{StaticResource Foreground}"
                           FontSize="13"
                           Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Actions'}"
                           FontFamily="Segoe UI Variable Text" />
                    <TextBlock Foreground="{StaticResource Foreground}"
                               FontSize="11"
                               Margin="2 0 0 10"
                               TextWrapping="Wrap"
                               Visibility="{Binding Converter={StaticResource helpVis}}"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='ActionsHelp'}"
                               FontFamily="Segoe UI Variable Text" />
                    <local:AutoPlayActionList x:Name="ActionsList"
                                              Actions="{Binding Profile.Actions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
