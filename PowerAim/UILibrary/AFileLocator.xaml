<UserControl x:Class="PowerAim.UILibrary.AFileLocator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:Ant="clr-namespace:AntWpf.Controls;assembly=AntWpf"
             xmlns:local="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             d:DesignWidth="282.5"
             Height="78">
    <Grid>
        <Border Height="78"
                Background="Transparent"
                BorderThickness="0">
            <Grid>
                <Label x:Name="DropdownTitle"
                       Padding="2,8,10,4"
                       FontFamily="Segoe UI Variable Text"
                       Content="Prediction Method"
                       Foreground="{DynamicResource FluentTextPrimary}"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       VerticalAlignment="Top"
                       Height="32" />

                <TextBox x:Name="FileLocationTextbox"
                         BorderBrush="{DynamicResource FluentStroke}"
                         Foreground="{DynamicResource FluentTextPrimary}"
                         BorderThickness="1"
                         TextWrapping="Wrap"
                         Text=""
                         Tag="No File Located"
                         VerticalAlignment="Top"
                         FontFamily="Segoe UI Variable Text"
                         FontSize="13"
                         Padding="8,0,8,0"
                         Style="{DynamicResource placeHolder}"
                         Background="{DynamicResource FluentSurface3}"
                         Margin="2,36,40,0"
                         Height="32"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center" />

                <Button x:Name="OpenFileB"
                        Style="{StaticResource FluentIconButton}"
                        Content="&#xE838;"
                        HorizontalAlignment="Right"
                        Height="32"
                        Width="32"
                        MinWidth="32"
                        MinHeight="32"
                        Margin="0,36,2,0"
                        VerticalAlignment="Top"
                        Padding="0"
                        FontSize="13"
                        Click="OpenFileB_Click" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
