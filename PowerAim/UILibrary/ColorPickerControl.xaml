<UserControl x:Class="PowerAim.UILibrary.ColorPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="268"
             d:DesignWidth="268" d:DesignHeight="320">
    <UserControl.Resources>
        <!-- Checkerboard tile used behind the alpha slider and the preview swatch -->
        <DrawingBrush x:Key="CheckerBrush" Viewport="0,0,10,10" ViewportUnits="Absolute" TileMode="Tile">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFCFCFCF">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,10,10" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FF7A7A7A">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,5,5" />
                                <RectangleGeometry Rect="5,5,5,5" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>

    <Border Background="{DynamicResource FluentSurface1}"
            BorderBrush="{DynamicResource FluentStroke}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
        <StackPanel>
            <!-- Saturation/Value plane + hue bar -->
            <Grid Height="150">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        x:Name="SvBox"
                        ClipToBounds="True"
                        CornerRadius="6"
                        Cursor="Cross"
                        MouseLeftButtonDown="SvBox_MouseDown"
                        BorderBrush="{DynamicResource FluentStrokeStrong}"
                        BorderThickness="1">
                    <Grid>
                        <Rectangle x:Name="SvHueFill" />
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Offset="0" Color="#FFFFFFFF" />
                                    <GradientStop Offset="1" Color="#00FFFFFF" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Offset="0" Color="#00000000" />
                                    <GradientStop Offset="1" Color="#FF000000" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Canvas x:Name="SvCanvas" IsHitTestVisible="False">
                            <Ellipse x:Name="SvThumb"
                                     Width="14" Height="14"
                                     Stroke="White" StrokeThickness="2"
                                     Effect="{x:Null}">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="Transparent" />
                                </Ellipse.Fill>
                            </Ellipse>
                        </Canvas>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        x:Name="HueBar"
                        Width="18"
                        Margin="10,0,0,0"
                        CornerRadius="6"
                        Cursor="SizeNS"
                        MouseLeftButtonDown="HueBar_MouseDown"
                        BorderBrush="{DynamicResource FluentStrokeStrong}"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Grid>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Offset="0.0000" Color="#FFFF0000" />
                                    <GradientStop Offset="0.1667" Color="#FFFFFF00" />
                                    <GradientStop Offset="0.3333" Color="#FF00FF00" />
                                    <GradientStop Offset="0.5000" Color="#FF00FFFF" />
                                    <GradientStop Offset="0.6667" Color="#FF0000FF" />
                                    <GradientStop Offset="0.8333" Color="#FFFF00FF" />
                                    <GradientStop Offset="1.0000" Color="#FFFF0000" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Canvas x:Name="HueCanvas" IsHitTestVisible="False">
                            <Border x:Name="HueThumb"
                                    Width="18" Height="6"
                                    Margin="-1,0,0,0"
                                    CornerRadius="2"
                                    BorderBrush="White" BorderThickness="2" />
                        </Canvas>
                    </Grid>
                </Border>
            </Grid>

            <!-- Alpha slider -->
            <Border x:Name="AlphaBar"
                    Height="18"
                    Margin="0,12,0,0"
                    CornerRadius="6"
                    Cursor="SizeWE"
                    MouseLeftButtonDown="AlphaBar_MouseDown"
                    BorderBrush="{DynamicResource FluentStrokeStrong}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid>
                    <Rectangle Fill="{StaticResource CheckerBrush}" />
                    <Rectangle x:Name="AlphaGrad" />
                    <Canvas x:Name="AlphaCanvas" IsHitTestVisible="False">
                        <Border x:Name="AlphaThumb"
                                Width="6" Height="18"
                                Margin="0,-1,0,0"
                                CornerRadius="2"
                                BorderBrush="White" BorderThickness="2" />
                    </Canvas>
                </Grid>
            </Border>

            <!-- Preview + hex -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="34" Height="32"
                        CornerRadius="6"
                        BorderBrush="{DynamicResource FluentStrokeStrong}"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Grid>
                        <Rectangle Fill="{StaticResource CheckerBrush}" />
                        <Rectangle x:Name="PreviewFill" />
                    </Grid>
                </Border>
                <TextBox Grid.Column="1"
                         x:Name="HexBox"
                         Margin="10,0,0,0"
                         Height="32"
                         VerticalContentAlignment="Center"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="13"
                         MaxLength="9"
                         KeyDown="HexBox_KeyDown"
                         LostFocus="HexBox_LostFocus" />
            </Grid>

            <!-- Preset swatches -->
            <ItemsControl x:Name="SwatchList" Margin="0,12,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Plain Border (not a Button): the app's implicit Button style swallows the
                             colored content, so the swatch looked empty. This paints the colour
                             directly and handles the click itself. -->
                        <Border Width="22" Height="22" Margin="0,0,6,6"
                                CornerRadius="4" Cursor="Hand"
                                BorderBrush="{DynamicResource FluentStrokeStrong}"
                                BorderThickness="1"
                                MouseLeftButtonDown="Swatch_Click"
                                Tag="{Binding}">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding}" />
                            </Border.Background>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
