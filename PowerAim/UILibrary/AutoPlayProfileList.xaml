<UserControl x:Class="UILibrary.AutoPlayProfileList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:AntWpf.Controls;assembly=AntWpf"
             xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderThickness="0" Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ListBox
                ItemsSource="{Binding Profiles, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Foreground="{DynamicResource FluentTextPrimary}"
                FontFamily="Segoe UI Variable Text"
                Margin="0"
                Padding="2"
                HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical">
                                <TextBlock
                                    Text="{Binding Name}"
                                    ToolTip="{Binding Description}"
                                    Foreground="{Binding Enabled, Converter={StaticResource boolToBrush}}"
                                    Opacity="{Binding IsActive, Converter={StaticResource boolToOpacity}}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,5,0" />
                                <TextBlock
                                    Text="{Binding OllamaModel}"
                                    FontSize="10"
                                    Opacity="0.6"
                                    Foreground="{DynamicResource FluentTextSecondary}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,5,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <uiLibrary:AToggle BorderBrush="Transparent" Text=""
                                                   Checked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Button Style="{StaticResource FluentIconButton}"
                                    ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Edit'}"
                                    Tag="{Binding}"
                                    MouseDown="UIElement_OnMouseDown"
                                    Click="EditProfile_Click"
                                    Foreground="{DynamicResource FluentTextPrimary}"
                                    Content="&#xEB7E;"
                                    Padding="0,0,0,0"
                                    FontSize="20"
                                    Width="50" />

                                <Button Style="{StaticResource FluentIconButton}"
                                    ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Delete'}"
                                    Tag="{Binding}"
                                    MouseDown="UIElement_OnMouseDown"
                                    Click="DeleteProfile_Click"
                                    Foreground="{DynamicResource FluentTextPrimary}"
                                    Content="&#xE74D;"
                                    Padding="0,0,0,0"
                                    FontSize="20"
                                    Width="50" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Grid.Row="1">
                <Button Style="{StaticResource FluentIconButton}"
                    HorizontalAlignment="Right"
                    ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AddProfile'}"
                    MouseDown="UIElement_OnMouseDown"
                    Click="AddProfile_Click"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    Content="&#xECC8;"
                    Padding="0,0,0,0"
                    FontSize="20"
                    Width="50" />
            </Border>
        </Grid>
    </Border>
</UserControl>
