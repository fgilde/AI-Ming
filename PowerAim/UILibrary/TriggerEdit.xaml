<UserControl x:Class="UILibrary.TriggerEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UILibrary"
             xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="760">
    <UserControl.Resources>
        <!-- Section icon style: 24×24 rounded accent badge -->
        <Style x:Key="SectionIcon" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource FluentAccent}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style x:Key="SectionIconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource FluentAccentForeground}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SectionTitleBig" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SectionSubtitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FluentTextTertiary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Small" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,1,0,0" />
        </Style>
        <Style x:Key="InlineRowLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
    </UserControl.Resources>
    <StackPanel HorizontalAlignment="Stretch">

        <!-- ====== Trigger ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xEC42;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Trigger" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Name and active state" />
                    </StackPanel>
                    <uiLibrary:AToggle Grid.Column="2"
                                       Background="Transparent" BorderBrush="Transparent"
                                       Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='EnabledActive'}"
                                       VerticalAlignment="Center"
                                       Checked="{Binding Trigger.Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBox Text="{Binding Trigger.Name, UpdateSourceTrigger=PropertyChanged}"
                         Tag="{Binding Converter={StaticResource localeConverter}, ConverterParameter='Name'}"
                         Style="{DynamicResource placeHolder}" />
            </StackPanel>
        </Border>

        <!-- ====== Per-Game Match (optional) ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE7C8;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Match process (optional)" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Only fire while a process matching the pattern is focused" />
                    </StackPanel>
                </Grid>
                <TextBox Text="{Binding Trigger.MatchProcess, UpdateSourceTrigger=PropertyChanged}"
                         Tag="cs2*, valorant, *fortnite*"
                         Style="{DynamicResource placeHolder}" />
                <TextBlock Style="{StaticResource FluentCaption}"
                           Margin="2,8,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding Converter={StaticResource helpVis}}"
                           Text="Supports wildcards (*, ?) and pipes (cs2|valorant). Leave empty for always-on. Requires 'Auto-switch profile by game' in Settings → Active Processes." />
            </StackPanel>
        </Border>

        <!-- ====== Actions ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE945;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}"
                                   Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='LabelTriggerActions'}" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Keys or buttons to send when triggered" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" x:Name="ModePanel" Orientation="Horizontal" VerticalAlignment="Center" />
                </Grid>
                <local:MultiKeyChanger AllowDuplicates="True"
                                       CanRecordSequence="True"
                                       Changed="MultiKeyChanger_OnChanged"
                                       Keys="{Binding Trigger.Actions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True}" />
                <TextBlock x:Name="TriggerActionsHelp"
                           Style="{StaticResource FluentCaption}"
                           Visibility="{Binding Converter={StaticResource helpVis}}"
                           Margin="2,8,0,0"
                           TextWrapping="Wrap"
                           Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='DescriptionTriggerActions'}" />
            </StackPanel>
        </Border>

        <!-- ====== Detection ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE7B3;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Detection" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Whether and how detection gates the trigger" />
                    </StackPanel>
                </Grid>

                <uiLibrary:AToggle Background="Transparent" BorderBrush="Transparent"
                                   Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='NeedsDetection'}"
                                   Checked="{Binding Trigger.NeedsDetection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Style="{StaticResource FluentCaption}"
                           Margin="2,0,0,8"
                           TextWrapping="Wrap"
                           Visibility="{Binding Converter={StaticResource helpVis}}"
                           Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='DescriptionNeedsDetection'}" />

                <StackPanel Visibility="{Binding Trigger.NeedsDetection, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource boolToVis}}">
                    <Border BorderBrush="{DynamicResource FluentStroke}" BorderThickness="0,1,0,0" Margin="0,4,0,12" />

                    <uiLibrary:AToggle Background="Transparent" BorderBrush="Transparent"
                                       Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='ChargeMode'}"
                                       Checked="{Binding Trigger.ChargeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock x:Name="ChargeModeDescription"
                               Style="{StaticResource FluentCaption}"
                               Margin="2,0,0,8"
                               TextWrapping="Wrap"
                               Visibility="{Binding Converter={StaticResource helpVis}}"
                               Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='ChargeModeToolTip'}" />

                    <!-- Charge entry check (only when Charge Mode on) -->
                    <Border Background="{DynamicResource FluentSurface3}"
                            BorderBrush="{DynamicResource FluentStroke}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8,12,10"
                            Margin="0,6,0,6"
                            Visibility="{Binding Trigger.ChargeMode, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource boolToVis}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FluentCaption}"
                                       Text="When charging begins"
                                       Margin="0,0,0,6" />
                            <Grid x:Name="ChargeEnterIntersectionBox">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Execution check -->
                    <Border Background="{DynamicResource FluentSurface3}"
                            BorderBrush="{DynamicResource FluentStroke}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8,12,10"
                            Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FluentCaption}"
                                       Text="When trigger fires"
                                       Margin="0,0,0,6" />
                            <Grid x:Name="IntersectionBox">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ====== Trigger Keys ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE765;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}"
                                   Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='LabelTriggerKeys'}" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Keys that must be pressed for the trigger to run" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock VerticalAlignment="Center" Margin="0,-10,18,0"
                                   Foreground="{DynamicResource FluentTextSecondary}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='TriggerKeysOperator'}" />
                        <StackPanel x:Name="TriggerKeyOperator" Orientation="Horizontal" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
                <local:MultiKeyChanger Keys="{Binding Trigger.TriggerKeys, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True}" />
                <TextBlock x:Name="DescriptionTriggerKeys"
                           Style="{StaticResource FluentCaption}"
                           Visibility="{Binding Converter={StaticResource helpVis}}"
                           Margin="2,8,0,0"
                           TextWrapping="Wrap"
                           Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='DescriptionTriggerKeys'}" />
            </StackPanel>
        </Border>

        <!-- ====== Anti Trigger Keys ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE711;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}"
                                   Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AntiTriggerKeys'}" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Keys that block the trigger when pressed" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock VerticalAlignment="Center" Margin="0,-10,18,0"
                                   Foreground="{DynamicResource FluentTextSecondary}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AntiTriggerKeysOperator'}" />
                        <StackPanel x:Name="AntiTriggerKeyOperator" Orientation="Horizontal" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
                <local:MultiKeyChanger Keys="{Binding Trigger.AntiTriggerKeys, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True}" />
                <TextBlock x:Name="DescriptionAntiTriggerKeys"
                           Style="{StaticResource FluentCaption}"
                           Visibility="{Binding Converter={StaticResource helpVis}}"
                           Margin="2,8,0,0"
                           TextWrapping="Wrap"
                           Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='DescriptionAntiTriggerKeys'}" />
            </StackPanel>
        </Border>

        <!-- ====== OCR Conditions (optional) ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE721;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}"
                                   Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='OcrConditions'}" />
                        <TextBlock Style="{StaticResource SectionSubtitle}"
                                   Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='OcrConditionsSubtitle'}" />
                    </StackPanel>
                </Grid>
                <StackPanel x:Name="OcrConditionsBox" />
            </StackPanel>
        </Border>

        <!-- ====== Timing ====== -->
        <Border Style="{StaticResource FluentCard}">
            <StackPanel>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionIcon}">
                        <TextBlock Text="&#xE916;" Style="{StaticResource SectionIconGlyph}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleBig}" Text="Timing" />
                        <TextBlock Style="{StaticResource SectionSubtitle}" Text="Delays and pauses between fires" />
                    </StackPanel>
                </Grid>
                <StackPanel x:Name="TimeSettings" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
