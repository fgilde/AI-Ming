<UserControl x:Class="PowerAim.UILibrary.Line"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             d:DesignWidth="282.5"
             d:DesignHeight="1"
             Height="1">
    <Grid>
        <Border Background="{DynamicResource FluentStroke}"
                BorderThickness="0"
                Margin="0,4,0,4" />
    </Grid>
</UserControl>
