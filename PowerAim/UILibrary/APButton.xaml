<UserControl x:Class="PowerAim.UILibrary.APButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PowerAim.UILibrary"
             mc:Ignorable="d"
             d:DesignWidth="282.5"
             d:DesignHeight="40">
    <Grid>
        <Border x:Name="OuterBorder"
                Height="40"
                Background="{DynamicResource FluentSurface3}"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{DynamicResource FluentStroke}"
                Margin="0,0,0,6">
            <Grid>
                <Label x:Name="ButtonTitle"
                       Padding="12,10,10,10"
                       FontFamily="Segoe UI Variable Text"
                       Content="Save Config"
                       Foreground="{DynamicResource FluentTextPrimary}"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       Margin="0,0,38,0" />

                <Label Padding="10,10,12,10"
                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                       Content="&#xE8B0;"
                       Foreground="{DynamicResource FluentTextSecondary}"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       HorizontalAlignment="Right"
                       HorizontalContentAlignment="Right" />

                <Button x:Name="Reader"
                        Background="Transparent"
                        BorderBrush="{x:Null}"
                        Cursor="Hand"
                        Padding="0"
                        Height="40" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
