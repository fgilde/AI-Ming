<UserControl x:Class="PowerAim.UILibrary.OllamaStatusIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:AntWpf.Controls;assembly=AntWpf"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="300">
    <Border Background="{DynamicResource FluentSurface2}"
            BorderThickness="1"
            BorderBrush="{DynamicResource FluentStroke}"
            CornerRadius="6"
            Margin="0,0,0,6"
            Padding="12,10,12,10">
        <StackPanel>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse x:Name="StatusIndicator"
                         Width="10" Height="10"
                         Fill="#E81123"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0" />

                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='OllamaChecking'}"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="13" />

                <Button Style="{StaticResource FluentIconButton}" x:Name="RefreshButton"
                                 Grid.Column="2"
                                 Content="&#xE72C;"
                                 ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='RefreshStatus'}"
                                 FontSize="13"
                                 BorderBrush="Transparent"
                                 Foreground="{DynamicResource FluentTextPrimary}"
                                 Padding="6"
                                 Click="RefreshButton_Click" />
            </Grid>

            <TextBlock x:Name="UrlText"
                       Text="URL: http://localhost:11434"
                       Foreground="{DynamicResource FluentTextSecondary}"
                       FontSize="11"
                       Margin="0,0,0,4"
                       FontFamily="Segoe UI Variable Small" />

            <TextBlock x:Name="ModelsText"
                       Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='ModelsDashFallback'}"
                       Foreground="{DynamicResource FluentTextSecondary}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"
                       FontFamily="Segoe UI Variable Small" />

            <TextBlock x:Name="ErrorText"
                       Text=""
                       Foreground="#E81123"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       FontFamily="Segoe UI Variable Small" />

            <TextBlock Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='InstallOllamaHint'}"
                       Foreground="{DynamicResource FluentTextTertiary}"
                       FontSize="10"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       Visibility="{Binding Converter={StaticResource helpVis}}"
                       FontFamily="Segoe UI Variable Small" />
        </StackPanel>
    </Border>
</UserControl>
