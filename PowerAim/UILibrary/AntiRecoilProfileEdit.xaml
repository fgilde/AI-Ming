<UserControl x:Class="UILibrary.AntiRecoilProfileEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:uiLibrary="clr-namespace:PowerAim.UILibrary"
             xmlns:local="clr-namespace:UILibrary"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="560">
    <StackPanel Margin="4,8,4,8">
        <!-- Identity -->
        <Label Foreground="{StaticResource Foreground}" FontSize="13" FontFamily="Segoe UI Variable Text"
               Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='ProfileName'}" />
        <TextBox BorderThickness="1" Padding="3 5 1 5" Margin="2,5"
                 Text="{Binding Profile.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 FontFamily="Segoe UI Variable Text"
                 BorderBrush="{DynamicResource FluentStroke}"
                 Background="Transparent"
                 Foreground="{StaticResource Foreground}" />

        <!-- Engine selector -->
        <Label Margin="0,12,0,0" Foreground="{StaticResource Foreground}" FontSize="13" FontFamily="Segoe UI Variable Text"
               Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AntiRecoilMode'}" />
        <ComboBox x:Name="ModeCombo" Margin="2,5" SelectionChanged="ModeCombo_SelectionChanged" />

        <!-- Mode-specific panels (sliders/combos populated in code-behind so we reuse
             AddSlider + BindTo extensions). Visibility is driven by ModeCombo. -->
        <StackPanel x:Name="LegacyPanel" Margin="0,10,0,0" />
        <StackPanel x:Name="ImageBasedPanel" Margin="0,10,0,0" />
        <StackPanel x:Name="PatternPanel" Margin="0,10,0,0" />

        <uiLibrary:Line Margin="0,10,0,10" />

        <!-- Activation: process filter + OCR weapon-match. The hotkey lives on the list row
             (matching the Mapping / Trigger pattern); no in-form hotkey UI any more. -->
        <Label Margin="0,8,0,0" Foreground="{StaticResource Foreground}" FontSize="12" FontFamily="Segoe UI Variable Text"
               Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='MatchProcessOptional'}" />
        <TextBox BorderThickness="1" Padding="3 5 1 5" Margin="2,5"
                 Text="{Binding Profile.MatchProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Tag="cs2*, valorant, *fortnite*"
                 FontFamily="Segoe UI Variable Text"
                 Style="{DynamicResource placeHolder}"
                 BorderBrush="{DynamicResource FluentStroke}"
                 Background="Transparent"
                 Foreground="{StaticResource Foreground}" />

        <uiLibrary:AToggle Margin="0,8,0,0"
                           BorderBrush="Transparent" Background="Transparent"
                           Text="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AntiRecoilAutoSwitchOnOcr'}"
                           Checked="{Binding Profile.AutoSwitchOnOcr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Label Foreground="{StaticResource Foreground}" FontSize="12" FontFamily="Segoe UI Variable Text"
               Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AntiRecoilOcrRegion'}"
               ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AntiRecoilOcrRegionHelp'}" />
        <Grid Margin="2,5,2,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="OcrRegionCombo" Grid.Column="0"
                      SelectionChanged="OcrRegionCombo_SelectionChanged"
                      IsEnabled="{Binding Profile.AutoSwitchOnOcr}" />
            <!-- Quick access to manage OCR regions without leaving the editor. -->
            <Button Grid.Column="1"
                    x:Name="EditRegionsButton"
                    Margin="6,0,0,0"
                    Padding="12,4,12,4"
                    MinHeight="28"
                    Style="{DynamicResource FluentStandardButton}"
                    Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='EditOcrRegionsButton'}"
                    ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='EditOcrRegionsButtonTooltip'}"
                    Click="EditRegions_Click" />
        </Grid>

        <Label Foreground="{StaticResource Foreground}" FontSize="12" FontFamily="Segoe UI Variable Text"
               Content="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AntiRecoilWeaponMatch'}"
               ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='AntiRecoilWeaponMatchHelp'}" />
        <TextBox BorderThickness="1" Padding="3 5 1 5" Margin="2,5"
                 Text="{Binding Profile.WeaponMatch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding Profile.AutoSwitchOnOcr}"
                 Tag="AK, Vandal, AWP, ..."
                 FontFamily="Segoe UI Variable Text"
                 Style="{DynamicResource placeHolder}"
                 BorderBrush="{DynamicResource FluentStroke}"
                 Background="Transparent"
                 Foreground="{StaticResource Foreground}" />
    </StackPanel>
</UserControl>
