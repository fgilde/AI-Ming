                            </Border>
                            <ScrollViewer Grid.Row="1"
                                          Padding="20,16,20,16"
                                          VerticalScrollBarVisibility="Auto"
                                          PanningMode="VerticalOnly">
                                <uiLibrary:MappingEdit x:Name="MappingEditor" />
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ================= STATUS BAR ================= -->
        <Border Grid.Row="1"
                Background="{StaticResource FluentSurface2}"
                BorderBrush="{StaticResource FluentStroke}"
                BorderThickness="0,1,0,0"
                Height="30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource FluentSubtleButton}"
                        HorizontalContentAlignment="Left"
                        HorizontalAlignment="Left"
                        Padding="14,2,12,2"
                        FontSize="11"
                        Foreground="{StaticResource FluentTextSecondary}"
                        Click="OpenConfig_CLick"
                        Content="{Binding Config.Path}" />
                <Menu Grid.Column="1"
                      Cursor="Hand"
                      Background="Transparent"
                      VerticalAlignment="Center"
                      Margin="0,0,14,0"
                      Height="22">
                    <MenuItem MaxHeight="120"
                              x:Name="ModelContextMenu"
                              FontSize="11"
                              FontFamily="Segoe UI Variable Small"
                              Header="{Binding Config.LastLoadedModel}"
                              Foreground="{StaticResource FluentTextSecondary}"
                              Padding="6,2,6,2"
                              VerticalAlignment="Top"
                              Height="22">
                        <MenuItem Header="Bold" />
                    </MenuItem>
                </Menu>
            </Grid>
        </Border>
    </Grid>
</visuality1:BaseDialog>
