                                            <TextBlock Style="{StaticResource FluentSectionTitle}"
                                                       Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='DownloadableConfigs'}" />
                                            <Label x:Name="LackOfConfigsText"
                                                   Visibility="Collapsed"
                                                   HorizontalContentAlignment="Center"
                                                   Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='NoDownloadableConfigAvailable'}"
                                                   Foreground="{StaticResource FluentTextSecondary}" />
                                            <StackPanel x:Name="ConfigStoreScroller" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

