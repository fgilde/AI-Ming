                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Style="{StaticResource FluentSectionTitle}"
                                                           Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Installed'}" />
                                                <Button Grid.Column="1"
                                                        x:Name="OpenFolderB_ConfigWindow"
                                                        Content="&#xE838;"
                                                        ToolTip="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='OpenConfigsFolder'}"
