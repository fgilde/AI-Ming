                                                                                   Text="" />
                                                            <Button Grid.Column="3"
                                                                    ToolTip="{Binding Converter={StaticResource localeConverter}, ConverterParameter='DeleteConfig'}"
                                                                    Style="{StaticResource FluentIconButton}"
                                                                    Content="&#xE74D;"
                                                                    Tag="{Binding}"
                                                                    MouseDown="UIElement_OnMouseDown"
                                                                    Click="DeleteConfig_Click"
                                                                    Width="32"
                                                                    Height="32" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>

                                    <!-- Available to download -->
                                    <Border Style="{StaticResource FluentCard}"
                                            Visibility="{x:Static poweraim:ApplicationConstants.EasyModeHidden}">
