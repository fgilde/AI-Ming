<launcher:BaseDialog x:Class="Launcher.MainWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:launcher="clr-namespace:Launcher"
                      xmlns:mdXaml="https://github.com/whistyun/MdXaml"
                      mc:Ignorable="d"
                      Height="600"
                      Width="560"
                      MinHeight="520"
                      MinWidth="500"
                      WindowStyle="None"
                      Topmost="False"
                      ResizeMode="CanResizeWithGrip"
                      Closing="MainWindow_OnClosing"
                      WindowStartupLocation="CenterScreen"
                      AllowsTransparency="True"
                      Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="boolToVis" />
    </Window.Resources>
    <Grid>
        <Border x:Name="MainBorder"
                CornerRadius="10"
                BorderBrush="{StaticResource FluentStroke}"
                BorderThickness="1"
                Background="{StaticResource FluentSurface1}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.40" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ============== Titlebar ============== -->
                <Grid Grid.Row="0"
                      Background="{StaticResource FluentSurface1}"
                      MouseLeftButtonDown="Border_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Image x:Name="AppLogo"
                               Source="/PowerAim.png"
                               Width="18" Height="18"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Title}"
                                   Margin="10,0,0,0"
                                   Foreground="{StaticResource FluentTextPrimary}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="Minimize"
                                Style="{StaticResource CaptionButton}"
                                Content="&#xE921;"
                                Visibility="{Binding InstallerVisibility}"
                                Click="Minimize_OnClick" />
                        <Button x:Name="Exit"
                                Style="{StaticResource CloseButton}"
                                Content="&#xE8BB;"
                                IsEnabled="{Binding CanClose}"
                                Visibility="{Binding InstallerVisibility}"
                                Click="Exit_OnClick" />
                    </StackPanel>
                </Grid>

                <!-- ============== Body ============== -->
                <Grid Grid.Row="1" Margin="24,8,24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Hero: big logo + title + subtitle -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,16">
                        <Image Source="/PowerAim.png"
                               Width="96" Height="96"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" />
                        <TextBlock Text="PowerAim"
                                   Foreground="{StaticResource FluentTextPrimary}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0" />
                        <TextBlock Text="Universal Second Eye"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,8" />
                        <TextBlock Text="{Binding Version}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   FontFamily="Segoe UI Variable Small"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding SubTitle}"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding Status}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   FontFamily="Segoe UI Variable Small"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <!-- Installer area -->
                    <Border Grid.Row="1"
                            Background="{StaticResource FluentSurface2}"
                            BorderBrush="{StaticResource FluentStroke}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Visibility="{Binding InstallerVisibility}">
                        <Grid x:Name="FolderSelect">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                       Text="Version"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontFamily="Segoe UI Variable Small"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <!-- Custom version picker: ToggleButton + Popup + ListBox (no WPF ComboBox shenanigans) -->
                            <Grid Grid.Row="1" Grid.ColumnSpan="2">
                                <ToggleButton x:Name="VersionDropToggle"
                                              MinHeight="34"
                                              Background="{StaticResource FluentSurface3}"
                                              BorderBrush="{StaticResource FluentStroke}"
                                              BorderThickness="1"
                                              Foreground="{StaticResource FluentTextPrimary}"
                                              Cursor="Hand"
                                              HorizontalContentAlignment="Stretch">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Padding="12,0,12,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding SelectedReleaseLabel}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{TemplateBinding Foreground}"
                                                               FontFamily="Segoe UI Variable Text"
                                                               FontSize="13" />
                                                    <Path Grid.Column="1"
                                                          x:Name="Chevron"
                                                          Data="M 0,0 L 4,4 L 8,0 Z"
                                                          Width="8" Height="4"
                                                          Fill="{StaticResource FluentTextSecondary}"
                                                          VerticalAlignment="Center"
                                                          Margin="6,0,0,0" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FluentAccent}" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FluentAccent}" />
                                                    <Setter TargetName="Chevron" Property="Fill" Value="{StaticResource FluentAccent}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup IsOpen="{Binding IsChecked, ElementName=VersionDropToggle, Mode=TwoWay}"
                                       PlacementTarget="{Binding ElementName=VersionDropToggle}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       MinWidth="{Binding ActualWidth, ElementName=VersionDropToggle}">
                                    <Border Background="{StaticResource FluentSurface2}"
                                            BorderBrush="{StaticResource FluentStroke}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="4"
                                            Margin="0,4,0,8"
                                            MinHeight="60">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.4" />
                                        </Border.Effect>
                                        <Grid>
                                            <TextBlock Text="No versions available"
                                                       Foreground="{StaticResource FluentTextTertiary}"
                                                       FontFamily="Segoe UI Variable Text"
                                                       FontSize="12"
                                                       Margin="10"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Releases.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <ListBox x:Name="VersionList"
                                                     MaxHeight="220"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="{StaticResource FluentTextPrimary}"
                                                     FontFamily="Segoe UI Variable Text"
                                                     FontSize="13"
                                                     ItemsSource="{Binding Releases}"
                                                     SelectedItem="{Binding SelectedRelease, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     SelectionChanged="VersionList_SelectionChanged">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding TagName}" Padding="10,6,10,6" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Cursor" Value="Hand" />
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border x:Name="bd"
                                                                            Background="{TemplateBinding Background}"
                                                                            CornerRadius="4"
                                                                            Margin="0,1,0,1">
                                                                        <ContentPresenter HorizontalAlignment="Stretch"
                                                                                          VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource FluentHoverOverlay}" />
                                                                        </Trigger>
                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource FluentAccent}" />
                                                                            <Setter Property="Foreground" Value="{StaticResource FluentAccentForeground}" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </Popup>
                            </Grid>

                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                                       Text="Execution mode"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontFamily="Segoe UI Variable Small"
                                       FontSize="11"
                                       Margin="0,12,0,4"
                                       Visibility="{Binding ContainsCudaRelease, Converter={StaticResource boolToVis}}" />
                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,4"
                                        Visibility="{Binding ContainsCudaRelease, Converter={StaticResource boolToVis}}">
                                <RadioButton x:Name="CudaCheckBox" GroupName="Executer" Content="CUDA" />
                                <RadioButton GroupName="Executer" IsChecked="True" Content="DirectML" Margin="20,0,0,0" />
                            </StackPanel>

                            <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                                       Text="Install location"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontFamily="Segoe UI Variable Small"
                                       FontSize="11"
                                       Margin="0,12,0,4" />
                            <TextBox Grid.Row="5" Grid.Column="0"
                                     Text="{Binding InstallDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="5" Grid.Column="1"
                                    Style="{StaticResource FluentStandardButton}"
                                    Click="SelectDir_Click"
                                    MinWidth="44"
                                    Margin="6,0,0,0"
                                    Content="…" />

                            <TextBlock Grid.Row="6" Grid.ColumnSpan="2"
                                       Text="Release notes"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontFamily="Segoe UI Variable Small"
                                       FontSize="11"
                                       Margin="0,12,0,4" />
                            <Border Grid.Row="7" Grid.ColumnSpan="2"
                                    Background="{StaticResource FluentSurface3}"
                                    BorderBrush="{StaticResource FluentStroke}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10"
                                    MinHeight="120">
                                <mdXaml:MarkdownScrollViewer
                                    HorizontalScrollBarVisibility="Auto"
                                    VerticalScrollBarVisibility="Auto"
                                    MarkdownStyle="{StaticResource MdStyle}"
                                    Markdown="{Binding SelectedRelease.Description}" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Footer: install actions -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0"
                                Visibility="{Binding InstallerVisibility}">
                        <Button IsEnabled="{Binding CanClose}"
                                Style="{StaticResource FluentStandardButton}"
                                Click="Exit_OnClick"
                                Content="Close"
                                MinWidth="100"
                                Margin="0,0,8,0"
                                Visibility="{Binding InstallVisibility}" />
                        <Button IsEnabled="{Binding CanInstall}"
                                Style="{StaticResource FluentAccentButton}"
                                Click="Install_Click"
                                Content="Install"
                                MinWidth="120" />
                    </StackPanel>
                </Grid>

                <!-- Hidden but kept for compatibility with code-behind -->
                <ProgressBar x:Name="ProgressBar"
                             Grid.Row="1"
                             VerticalAlignment="Bottom"
                             Visibility="Collapsed"
                             Minimum="0" Maximum="100"
                             Margin="24,0,24,12" />
            </Grid>
        </Border>
    </Grid>
</launcher:BaseDialog>
