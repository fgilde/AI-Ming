<launcher:BaseDialog x:Class="Launcher.MainWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:launcher="clr-namespace:Launcher"
                      xmlns:mdXaml="https://github.com/whistyun/MdXaml"
                      mc:Ignorable="d"
                      Height="600"
                      Width="560"
                      MinHeight="520"
                      MinWidth="500"
                      WindowStyle="None"
                      Topmost="False"
                      ResizeMode="CanResizeWithGrip"
                      Closing="MainWindow_OnClosing"
                      WindowStartupLocation="CenterScreen"
                      AllowsTransparency="True"
                      Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="boolToVis" />
    </Window.Resources>
    <Grid>
        <Border x:Name="MainBorder"
                CornerRadius="10"
                BorderBrush="{StaticResource FluentStroke}"
                BorderThickness="1"
                Background="{StaticResource FluentSurface1}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.40" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ============== Titlebar ============== -->
                <Grid Grid.Row="0"
                      Background="{StaticResource FluentSurface1}"
                      MouseLeftButtonDown="Border_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Image x:Name="AppLogo"
                               Source="/PowerAim.png"
                               Width="18" Height="18"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Title}"
                                   Margin="10,0,0,0"
                                   Foreground="{StaticResource FluentTextPrimary}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="Minimize"
                                Style="{StaticResource CaptionButton}"
                                Content="&#xE921;"
                                Visibility="{Binding InstallerVisibility}"
                                Click="Minimize_OnClick" />
                        <Button x:Name="Exit"
                                Style="{StaticResource CloseButton}"
                                Content="&#xE8BB;"
                                IsEnabled="{Binding CanClose}"
                                Visibility="{Binding InstallerVisibility}"
                                Click="Exit_OnClick" />
                    </StackPanel>
                </Grid>

                <!-- ============== Body ============== -->
                <Grid Grid.Row="1" Margin="24,8,24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Hero: big logo + title + subtitle -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,16">
                        <Image Source="/PowerAim.png"
                               Width="96" Height="96"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" />
                        <TextBlock Text="PowerAim"
                                   Foreground="{StaticResource FluentTextPrimary}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0" />
                        <TextBlock Text="Universal Second Eye"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,8" />
                        <TextBlock Text="{Binding Version}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   FontFamily="Segoe UI Variable Small"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding SubTitle}"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding Status}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   FontFamily="Segoe UI Variable Small"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <!-- Installer area -->
                    <Border Grid.Row="1"
                            Background="{StaticResource FluentSurface2}"
                            BorderBrush="{StaticResource FluentStroke}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Visibility="{Binding InstallerVisibility}">
                        <Grid x:Name="FolderSelect">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                       Text="Version"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontFamily="Segoe UI Variable Small"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <ComboBox Grid.Row="1" Grid.ColumnSpan="2"
                                      SelectedItem="{Binding SelectedRelease, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding Releases}"
                                      DisplayMemberPath="TagName" />

                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                                       Text="Execution mode"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontFamily="Segoe UI Variable Small"
                                       FontSize="11"
                                       Margin="0,12,0,4"
                                       Visibility="{Binding ContainsCudaRelease, Converter={StaticResource boolToVis}}" />
                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,4"
                                        Visibility="{Binding ContainsCudaRelease, Converter={StaticResource boolToVis}}">
                                <RadioButton x:Name="CudaCheckBox" GroupName="Executer" Content="CUDA" />
                                <RadioButton GroupName="Executer" IsChecked="True" Content="DirectML" Margin="20,0,0,0" />
                            </StackPanel>

                            <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                                       Text="Install location"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontFamily="Segoe UI Variable Small"
                                       FontSize="11"
                                       Margin="0,12,0,4" />
                            <TextBox Grid.Row="5" Grid.Column="0"
                                     Text="{Binding InstallDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="5" Grid.Column="1"
                                    Style="{StaticResource FluentStandardButton}"
                                    Click="SelectDir_Click"
                                    MinWidth="44"
                                    Margin="6,0,0,0"
                                    Content="…" />

                            <TextBlock Grid.Row="6" Grid.ColumnSpan="2"
                                       Text="Release notes"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontFamily="Segoe UI Variable Small"
                                       FontSize="11"
                                       Margin="0,12,0,4" />
                            <Border Grid.Row="7" Grid.ColumnSpan="2"
                                    Background="{StaticResource FluentSurface3}"
                                    BorderBrush="{StaticResource FluentStroke}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10"
                                    MinHeight="120">
                                <mdXaml:MarkdownScrollViewer
                                    HorizontalScrollBarVisibility="Auto"
                                    VerticalScrollBarVisibility="Auto"
                                    MarkdownStyle="{StaticResource MdStyle}"
                                    Markdown="{Binding SelectedRelease.Description}" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Footer: install actions -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0"
                                Visibility="{Binding InstallerVisibility}">
                        <Button IsEnabled="{Binding CanClose}"
                                Style="{StaticResource FluentStandardButton}"
                                Click="Exit_OnClick"
                                Content="Close"
                                MinWidth="100"
                                Margin="0,0,8,0"
                                Visibility="{Binding InstallVisibility}" />
                        <Button IsEnabled="{Binding CanClose}"
                                Style="{StaticResource FluentAccentButton}"
                                Click="Install_Click"
                                Content="Install"
                                MinWidth="120" />
                    </StackPanel>
                </Grid>

                <!-- Hidden but kept for compatibility with code-behind -->
                <ProgressBar x:Name="ProgressBar"
                             Grid.Row="1"
                             VerticalAlignment="Bottom"
                             Visibility="Collapsed"
                             Minimum="0" Maximum="100"
                             Margin="24,0,24,12" />
            </Grid>
        </Border>
    </Grid>
</launcher:BaseDialog>
