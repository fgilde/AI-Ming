<local:BaseDialog x:Class="Visuality.MagnifierDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Visuality"
        mc:Ignorable="d"
        Height="500"
        Width="600"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        ForceCursor="False"
        Cursor="None"
        PreviewMouseLeftButtonDown="Border_MouseLeftButtonDown"
        Background="Green">

    <Grid>
        <Button  x:Name="Exit" Content="&#xE8BB;" HorizontalAlignment="Right" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White" FontFamily="Segoe MDL2 Assets" Padding="15,0,15,0" BorderThickness="0,0,0,0" FontSize="10" VerticalAlignment="Top" Click="Exit_Click" />

        <Border x:Name="MainBorder"
                CornerRadius="5"
                BorderThickness="1"
                Background="Transparent">
            
        </Border>
    </Grid>
</local:BaseDialog>
