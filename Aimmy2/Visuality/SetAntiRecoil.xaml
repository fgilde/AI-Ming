<Window x:Class="Visuality.SetAntiRecoil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:Ant="clr-namespace:AntWpf.Controls;assembly=AntWpf"
        xmlns:local="clr-namespace:Visuality"
        xmlns:aimmy2="clr-namespace:Aimmy2"
        mc:Ignorable="d"
        Title="Set Static FOV Positioning"
        Background="Transparent"
        Foreground="{x:Null}"
        Topmost="True"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Width="1920"
        Height="1080">
    <Grid>
        <Border VerticalAlignment="Top"
                Background="{StaticResource Background}"
                Height="200">
            <Grid>
                <Label Content="{x:Static aimmy2:ApplicationConstants.ApplicationName}"
                       Foreground="{DynamicResource FluentTextPrimary}"
                       FontFamily="{StaticResource AKONY}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="25,25,0,0"
                       FontSize="20"
                       Padding="0,0,0,0" />
                <Label x:Name="SettingLabel"
                       VerticalAlignment="Top"
                       Foreground="{DynamicResource FluentTextPrimary}"
                       FontFamily="Segoe UI Variable Text"
                       Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='AntiRecoilHelp'}"
                       FontSize="20"
                       VerticalContentAlignment="Center"
                       Padding="0"
                       Margin="25,50,25,0" />

                <Button x:Name="Exit" Content="&#xE8BB;" Margin="0 25 20 0" HorizontalAlignment="Right" Background="Transparent" BorderBrush="{x:Null}" Foreground="White" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Padding="15,0,15,0" BorderThickness="0,0,0,0" FontSize="14" VerticalAlignment="Top" Click="Exit_Click" />
            </Grid>
        </Border>
        <Border x:Name="BulletBorder"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Background="{StaticResource Background}"
                Width="270"
                Height="140"
                CornerRadius="5,5,5,5"
                BorderBrush="Black"
                BorderThickness="1,1,1,1"
                Margin="0,0,0,100">
            
            <Grid>
                <Label Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='QuestionBulletCount'}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Foreground="{DynamicResource FluentTextPrimary}"
                       Padding="0,0,0,0"
                       FontFamily="Segoe UI Variable Text"
                       Margin="0,22,0,0" />
                <Border VerticalAlignment="Top"
                        Height="35"
                        Margin="10,46,10,0"
                        Background="{DynamicResource FluentSurface2}"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="5" />
                <TextBox x:Name="BulletNumberTextbox"
                         BorderThickness="1"
                         TextWrapping="Wrap"
                         Tag="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='InsertNumberHere'}"
                         VerticalAlignment="Top"
                         FontFamily="Segoe UI Variable Text"
                         Padding="5,5,5,5"
                         Style="{DynamicResource placeHolder}"
                         BorderBrush="{x:Null}"
                         Background="Transparent"
                         Foreground="White"
                         Margin="10,46,10,0"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         TextChanged="BulletNumberTextbox_TextChanged" />
                <Button x:Name="ConfirmB"
                        Style="{StaticResource FluentAccentButton}"
                        Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Confirm'}"
                        HorizontalAlignment="Left"
                        MinWidth="90"
                        VerticalAlignment="Bottom"
                        Click="ConfirmB_Click"
                        Margin="64,0,0,20" />
                <Button x:Name="TryAgainB"
                        Style="{StaticResource FluentStandardButton}"
                        Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='TryAgain'}"
                        HorizontalAlignment="Left"
                        MinWidth="90"
                        VerticalAlignment="Top"
                        Click="TryAgainB_Click"
                        Margin="139,94,0,0" />
            </Grid>
        </Border>
    </Grid>
</Window>