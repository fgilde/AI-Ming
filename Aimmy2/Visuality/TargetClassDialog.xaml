<visuality:BaseDialog x:Class="Aimmy2.Visuality.TargetClassDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:visuality="clr-namespace:Aimmy2.Visuality"
        mc:Ignorable="d"
        Title="Target Classes"
        Height="520"
        Width="460"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="False"
        Background="{DynamicResource FluentSurface1}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="&#xE71D;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           Foreground="{DynamicResource FluentAccent}"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="TitleText"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Text="Target Classes" />
            </StackPanel>
            <Button HorizontalAlignment="Right"
                    Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Content="&#xE8BB;" Width="46" Height="40" Padding="0" FontSize="10"
                    VerticalAlignment="Top"
                    Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Filter-mode toggle -->
        <Border Grid.Row="1" Margin="16,4,16,10"
                Background="{DynamicResource FluentSurface2}"
                BorderBrush="{DynamicResource FluentStroke}"
                BorderThickness="1"
                CornerRadius="6" Padding="14,10,14,10">
            <StackPanel>
                <TextBlock x:Name="ModeLabel" Text="Filter mode"
                           Foreground="{DynamicResource FluentTextSecondary}"
                           FontFamily="Segoe UI Variable Small" FontSize="11"
                           Margin="0,0,0,6" />
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="RbAll" Content="All Classes" GroupName="FilterMode"
                                 Foreground="{DynamicResource FluentTextPrimary}"
                                 FontFamily="Segoe UI Variable Text" FontSize="13"
                                 Margin="0,0,18,0" IsChecked="True"
                                 Checked="Rb_Checked" />
                    <RadioButton x:Name="RbSpecific" Content="Only selected" GroupName="FilterMode"
                                 Foreground="{DynamicResource FluentTextPrimary}"
                                 FontFamily="Segoe UI Variable Text" FontSize="13"
                                 Checked="Rb_Checked" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Class list -->
        <Border Grid.Row="2" Margin="16,0,16,12"
                Background="{DynamicResource FluentSurface2}"
                BorderBrush="{DynamicResource FluentStroke}"
                BorderThickness="1"
                CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6,4,6,4">
                <StackPanel x:Name="ClassListPanel" />
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="HelpText"
                       Foreground="{DynamicResource FluentTextTertiary}"
                       FontFamily="Segoe UI Variable Small" FontSize="11"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
            <Button Grid.Column="1" x:Name="CancelButton" Content="Cancel"
                    MinWidth="96" MinHeight="34"
                    Margin="0,0,8,0" Padding="14,6,14,6"
                    Style="{DynamicResource FluentStandardButton}"
                    Click="Cancel_Click" />
            <Button Grid.Column="2" x:Name="SaveButton" Content="Save"
                    MinWidth="100" MinHeight="34"
                    Padding="14,6,14,6"
                    Style="{DynamicResource FluentAccentButton}"
                    Click="Save_Click" />
        </Grid>
    </Grid>
</visuality:BaseDialog>
