<visuality:BaseDialog x:Class="Visuality.EditHeadArea"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Visuality"
        xmlns:converter="clr-namespace:Aimmy2.Converter"
        xmlns:visuality="clr-namespace:Aimmy2.Visuality"
        mc:Ignorable="d"
        Title="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='EditHeadArea'}"
        Height="640"
        Width="900"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        IsVisibleChanged="EditHeadArea_OnIsVisibleChanged"
        AllowsTransparency="False"
        Background="{StaticResource FluentSurface1}">
    <Window.Resources>
        <converter:AddConverter x:Key="AddConverter" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="&#xEE57;"
                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                           Foreground="{DynamicResource FluentAccent}"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='EditHeadArea'}"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource FluentTextPrimary}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="13" />
            </StackPanel>
            <Button x:Name="Exit"
                    Content="&#xE8BB;"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource FluentTextPrimary}"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Width="46"
                    Height="40"
                    Padding="0"
                    FontSize="10"
                    VerticalAlignment="Top"
                    Click="Exit_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Help row -->
        <TextBlock Grid.Row="1"
                   Margin="14,0,14,8"
                   Foreground="{DynamicResource FluentTextSecondary}"
                   FontFamily="Segoe UI Variable Small"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='HeadAreaHelp'}" />

        <!-- Body: preview area + sliders -->
        <Grid x:Name="MainArea" Grid.Row="2" Margin="14,0,14,8" MouseMove="MainArea_MouseMove" MouseUp="MainArea_MouseUp">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Preview / drag area -->
            <Border Grid.Column="0"
                    Style="{StaticResource FluentCard}"
                    Margin="0,0,8,0"
                    Padding="12">
                <Border BorderBrush="{DynamicResource FluentAccent}"
                        BorderThickness="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="{x:Static local:EditHeadArea.ContainerWidth}"
                        Height="{x:Static local:EditHeadArea.ContainerHeight}"
                        Background="{DynamicResource FluentSurface3}"
                        CornerRadius="4">
                    <Canvas>
                        <Rectangle x:Name="GreenRectangle"
                                   Stroke="{DynamicResource FluentAccent}"
                                   StrokeThickness="2"
                                   Fill="Transparent"
                                   Width="{Binding Path=RectWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   Height="{Binding Path=RectHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   Canvas.Left="{Binding Path=RectLeft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   Canvas.Top="{Binding Path=RectTop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   MouseDown="GreenRectangle_MouseDown"
                                   Cursor="SizeAll" />
                        <Rectangle x:Name="ResizeHandleBottomRight"
                                   Width="10"
                                   Height="10"
                                   Fill="{DynamicResource FluentAccent}"
                                   MouseDown="ResizeHandle_MouseDown"
                                   Cursor="SizeNWSE">
                            <Rectangle.RenderTransform>
                                <TransformGroup>
                                    <TranslateTransform>
                                        <TranslateTransform.X>
                                            <MultiBinding Converter="{StaticResource AddConverter}">
                                                <Binding Path="RectLeft" />
                                                <Binding Path="RectWidth" />
                                            </MultiBinding>
                                        </TranslateTransform.X>
                                        <TranslateTransform.Y>
                                            <MultiBinding Converter="{StaticResource AddConverter}">
                                                <Binding Path="RectTop" />
                                                <Binding Path="RectHeight" />
                                            </MultiBinding>
                                        </TranslateTransform.Y>
                                    </TranslateTransform>
                                </TransformGroup>
                            </Rectangle.RenderTransform>
                        </Rectangle>
                    </Canvas>
                </Border>
            </Border>

            <!-- Slider panel -->
            <Border Grid.Column="1"
                    Style="{StaticResource FluentCard}"
                    Margin="8,0,0,0"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Geometry"
                               Foreground="{DynamicResource FluentTextPrimary}"
                               FontFamily="Segoe UI Variable Display"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Margin="0,0,0,10" />

                    <TextBlock Name="WidthText"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Width'}" />
                    <Slider Minimum="0.01" Maximum="1.0"
                            ValueChanged="Slider_OnValueChanged"
                            Value="{Binding Path=RelativeRect.WidthPercentage, Mode=TwoWay}"
                            TickFrequency="0.01"
                            IsSnapToTickEnabled="True"
                            Margin="0,4,0,12" />

                    <TextBlock Name="HeightText"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Height'}" />
                    <Slider Minimum="0.01" Maximum="1.0"
                            ValueChanged="Slider_OnValueChanged"
                            Value="{Binding Path=RelativeRect.HeightPercentage, Mode=TwoWay}"
                            TickFrequency="0.01"
                            IsSnapToTickEnabled="True"
                            Margin="0,4,0,12" />

                    <TextBlock Name="LeftText"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Left'}" />
                    <Slider Minimum="0.0" Maximum="1.0"
                            ValueChanged="Slider_OnValueChanged"
                            Value="{Binding Path=RelativeRect.LeftMarginPercentage, Mode=TwoWay}"
                            TickFrequency="0.01"
                            IsSnapToTickEnabled="True"
                            Margin="0,4,0,12" />

                    <TextBlock Name="TopText"
                               Foreground="{DynamicResource FluentTextSecondary}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               Text="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Top'}" />
                    <Slider Minimum="0.0" Maximum="1.0"
                            ValueChanged="Slider_OnValueChanged"
                            Value="{Binding Path=RelativeRect.TopMarginPercentage, Mode=TwoWay}"
                            TickFrequency="0.01"
                            IsSnapToTickEnabled="True"
                            Margin="0,4,0,16" />

                    <Button x:Name="ResetButton"
                            Style="{StaticResource FluentStandardButton}"
                            Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Reset'}"
                            HorizontalAlignment="Stretch"
                            Click="Reset_Click" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,14,14">
            <Button x:Name="CancelButton"
                    Style="{StaticResource FluentStandardButton}"
                    Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Cancel'}"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Click="Exit_Click" />
            <Button x:Name="SaveButton"
                    Style="{StaticResource FluentAccentButton}"
                    Content="{Binding Path=Texts, Converter={StaticResource localeConverter}, ConverterParameter='Save'}"
                    MinWidth="100"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</visuality:BaseDialog>
