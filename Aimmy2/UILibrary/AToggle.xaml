<UserControl x:Class="Aimmy2.UILibrary.AToggle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Aimmy2.UILibrary"
             mc:Ignorable="d"
             Opacity="{Binding EnabledOpacity, RelativeSource={RelativeSource AncestorType=local:AToggle}}"
             d:DesignWidth="282.5"
             d:DesignHeight="40">
    <Grid>
        <Border Height="40"
                Background="Transparent">
            <Grid>
                <Label x:Name="ToggleTitle"
                       Padding="2,10,10,10"
                       FontFamily="Segoe UI Variable Text"
                       Content="{Binding Text, RelativeSource={RelativeSource AncestorType=local:AToggle}}"
                       Foreground="{DynamicResource FluentTextPrimary}"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       Margin="0,0,52,0" />

                <Border x:Name="SwitchBorder"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="40"
                        Height="20"
                        CornerRadius="10"
                        Margin="0,0,8,0"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource FluentStrokeStrong}"
                        Background="{DynamicResource FluentSurface3}">
                    <Border x:Name="SwitchMoving"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="14"
                            Height="14"
                            Background="#FFFFFFFF"
                            CornerRadius="7"
                            Margin="0,0,22,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="2" ShadowDepth="0" Opacity="0.25" />
                        </Border.Effect>
                    </Border>
                </Border>

                <Button Click="ButtonBase_OnClick"
                        Background="Transparent"
                        BorderBrush="{x:Null}"
                        Cursor="Hand"
                        Padding="0"
                        Height="40" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
