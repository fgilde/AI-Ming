<UserControl x:Class="Aimmy2.UILibrary.AColorChanger"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Aimmy2.UILibrary"
             mc:Ignorable="d"
             d:DesignWidth="282.5"
             d:DesignHeight="40">
    <Grid>
        <Border Height="40"
                Background="Transparent"
                BorderThickness="0">
            <Grid>
                <Label x:Name="ColorChangerTitle"
                       Padding="2,10,10,10"
                       FontFamily="Segoe UI Variable Text"
                       Content="{Binding Title}"
                       Foreground="{DynamicResource FluentTextPrimary}"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       Margin="0,0,76,0" />

                <Border x:Name="ColorChangingBorder"
                        HorizontalAlignment="Right"
                        Width="24"
                        Height="20"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource FluentStrokeStrong}">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding Color}" />
                    </Border.Background>
                </Border>

                <Button x:Name="Reader"
                        Click="ChangeColorClick"
                        Background="Transparent"
                        BorderBrush="{x:Null}"
                        Cursor="Hand"
                        Padding="0"
                        Height="40"
                        Margin="0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
