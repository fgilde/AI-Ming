<UserControl x:Class="UILibrary.MultiKeyChanger"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UILibrary"
             xmlns:uiLibrary="clr-namespace:Aimmy2.UILibrary"
             xmlns:aimmy2="clr-namespace:Aimmy2"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <ItemsControl Focusable="False" IsTabStop="False" BorderBrush="#3FFFFFFF" BorderThickness="1" ItemsSource="{Binding Keys, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=local:MultiKeyChanger}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="8">
                        <uiLibrary:AKeyChanger Background="Transparent" BorderBrush="Transparent" Text=""
                                           BindingManager="{Binding BindingManager, RelativeSource={RelativeSource AncestorType=local:MultiKeyChanger}}" 
                                           WithBorder="False"
                                           CanRemoveBinding="true"
                                           InvalidText="Add"
                                           Tag="{Binding}"
                                           KeyBindChanged="AKeyChanger_OnKeyBindChanged"
                                           KeyBind="{Binding Path=., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True}" />
                        <Border BorderBrush="#3FFFFFFF"
                                BorderThickness="1"
                                Cursor="Hand"
                                Tag="{Binding}"
                                Visibility="{Binding IsValid, Converter={StaticResource boolToVis}}"
                                MouseLeftButtonDown="Remove_Key_Click"
                                Background="Black"
                                Margin="-3,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                MinWidth="15"
                                MinHeight="15"
                                CornerRadius="2">
                            <Grid>
                                <Label 
                                    FontFamily="Segoe MDL2 Assets"
                                    Content="&#xE74D;"
                                    Padding="4"
                                    FontSize="12"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Foreground="White" />
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Label Grid.Row="1"
               Content="{Binding ErrorMessage, RelativeSource={RelativeSource AncestorType=local:MultiKeyChanger}}"
               Foreground="Red"
               >
        
        </Label>
    </Grid>
</UserControl>
