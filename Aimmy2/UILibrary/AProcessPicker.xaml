<UserControl x:Class="Aimmy2.UILibrary.AProcessPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:Ant="clr-namespace:AntWpf.Controls;assembly=AntWpf"
             xmlns:local="clr-namespace:Aimmy2.UILibrary"
             mc:Ignorable="d"
             d:DesignWidth="282.5"
             d:DesignHeight="40">
    <Grid>
        <Border Height="40"
                Background="{DynamicResource FluentSurface2}"
                CornerRadius="0"
                BorderThickness="1,0,1,0"
                BorderBrush="{DynamicResource FluentStroke}">
            <Grid>
                <Label x:Name="ProcessPickerTitle"
                       Padding="10,10,10,10"
                       FontFamily="Segoe UI Variable Text"
                       Content="{Binding SelectedProcessModel}"
                       Foreground="{DynamicResource FluentTextPrimary}"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       Margin="0,0,76,0" />

                <Border HorizontalAlignment="Right"
                        Margin="0,5,10,6"
                        BorderBrush="{DynamicResource FluentStroke}"
                        BorderThickness="1"
                        CornerRadius="5">
                    <Grid>
                        <Label FontFamily="Segoe UI Variable Text"
                               Content="Select Process..."
                               FontSize="13"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Padding="10,0,10,0"
                               Foreground="{DynamicResource FluentTextPrimary}" />
                    </Grid>
                </Border>

                <Button x:Name="ProcessPickerButton"
                        Background="Transparent"
                        BorderBrush="{x:Null}"
                        Padding="0,0,0,0"
                        Height="40"
                        Margin="0"
                        Click="ProcessPickerButton_Click">
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>